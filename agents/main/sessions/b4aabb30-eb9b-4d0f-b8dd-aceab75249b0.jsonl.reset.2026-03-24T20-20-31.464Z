{"type":"message","id":"8630db96","parentId":"de6d7bd0","timestamp":"2026-03-24T17:21:26.157Z","message":{"role":"toolResult","toolCallId":"call_rab70ribhm3qbssadow40bvb","toolName":"cron","content":[{"type":"text","text":"{\n  \"jobs\": [\n    {\n      \"id\": \"c90cfb67-9d24-4c63-96b9-f5c1766de045\",\n      \"name\": \"每日辛苦提醒\",\n      \"description\": \"龙龙仔每天凌晨2:25发送暖心提醒\",\n      \"enabled\": true,\n      \"createdAtMs\": 1773771690298,\n      \"updatedAtMs\": 1774290305394,\n      \"schedule\": {\n        \"kind\": \"cron\",\n        \"expr\": \"25 2 * * *\"\n      },\n      \"sessionTarget\": \"isolated\",\n      \"wakeMode\": \"now\",\n      \"payload\": {\n        \"kind\": \"agentTurn\",\n        \"message\": \"工作辛苦了！记得早点休息 💤\\n\\n@刘成龙 @逄格娟\"\n      },\n      \"delivery\": {\n        \"mode\": \"announce\",\n        \"channel\": \"dingtalk-connector\",\n        \"to\": \"chat:6940612436280423\"\n      },\n      \"state\": {\n        \"nextRunAtMs\": 1774376700000,\n        \"lastRunAtMs\": 1774290300007,\n        \"lastStatus\": \"ok\",\n        \"lastDurationMs\": 5387,\n        \"consecutiveErrors\": 0,\n        \"lastRunStatus\": \"ok\",\n        \"lastDelivered\": true,\n        \"lastDeliveryStatus\": \"delivered\"\n      }\n    }\n  ],\n  \"total\": 1,\n  \"offset\": 0,\n  \"limit\": 1,\n  \"hasMore\": false,\n  \"nextOffset\": null\n}"}],"details":{"jobs":[{"id":"c90cfb67-9d24-4c63-96b9-f5c1766de045","name":"每日辛苦提醒","description":"龙龙仔每天凌晨2:25发送暖心提醒","enabled":true,"createdAtMs":1773771690298,"updatedAtMs":1774290305394,"schedule":{"kind":"cron","expr":"25 2 * * *"},"sessionTarget":"isolated","wakeMode":"now","payload":{"kind":"agentTurn","message":"工作辛苦了！记得早点休息 💤\n\n@刘成龙 @逄格娟"},"delivery":{"mode":"announce","channel":"dingtalk-connector","to":"chat:6940612436280423"},"state":{"nextRunAtMs":1774376700000,"lastRunAtMs":1774290300007,"lastStatus":"ok","lastDurationMs":5387,"consecutiveErrors":0,"lastRunStatus":"ok","lastDelivered":true,"lastDeliveryStat