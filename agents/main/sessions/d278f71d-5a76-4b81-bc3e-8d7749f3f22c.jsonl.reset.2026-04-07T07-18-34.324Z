  - generic \"Mar 31, 2026, 3:56 PM GMT+8\" [ref=e183]: on Mar 31, 2026last week\n                  - button \"Issue body actions\" [ref=e187] [cursor=pointer]:\n                    - img [ref=e188]\n                - generic [ref=e190]:\n                  - generic [ref=e192]:\n                    - heading \"Bug type\" [level=3] [ref=e193]\n                    - paragraph [ref=e194]: Behavior bug (incorrect output/state without crash)\n                    - heading \"Beta release blocker\" [level=3] [ref=e195]\n                    - paragraph [ref=e196]: \"No\"\n                    - heading \"Summary\" [level=3] [ref=e197]\n                    - 'heading \"Bug Report: openclaw browser CLI present but gateway returns unknown method: browser.request\" [level=1] [ref=e198]':\n                      - text: \"Bug Report:\"\n                      - code [ref=e199]: openclaw browser\n                      - text: CLI present but gateway returns\n                      - code [ref=e200]: \"unknown method: browser.request\"\n                    - heading \"Summary\" [level=2] [ref=e201]\n                    - paragraph [ref=e202]:\n                      - text: On a macOS local OpenClaw install, the\n                      - code [ref=e203]: openclaw browser\n                      - text: CLI is present and the bundled\n                      - code [ref=e204]: browser\n                      - text: \"plugin appears loaded, but all browser commands fail because the gateway responds with:\"\n                    - list [ref=e205]:\n                      - listitem [ref=e206]:\n                        - code [ref=e207]: \"GatewayClientRequestError: unknown method: browser.request\"\n                    - paragraph [ref=e208]: \"This happens even after:\"\n                    - list [ref=e209]:\n                      - listitem [ref=e210]:\n                        - text: confirming browser config is present in\n                        - code [ref=e211]: ~/.openclaw/openclaw.json\n                      - listitem [ref=e212]: confirming the gateway is healthy and restarting cleanly\n                      - listitem [ref=e213]: resolving device pairing issues\n                      - listitem [ref=e214]:\n                        - text: confirming the browser plugin is listed as loaded and claims to expose\n                        - code [ref=e215]: browser.request\n                      - listitem [ref=e216]: attempting a browser plugin disable/re-enable cycle\n                    - paragraph [ref=e217]: This looks like a browser plugin/runtime registration mismatch or packaging/runtime bug, not a user configuration problem.\n                    - separator [ref=e218]\n                    - heading \"OpenClaw version\" [level=2] [ref=e219]\n                    - list [ref=e220]:\n                      - listitem [ref=e221]:\n                        - text: \"OpenClaw:\"\n                        - code [ref=e222]: 2026.3.28 (f9b1079)\n                    - heading \"Environment\" [level=2] [ref=e223]\n                    - list [ref=e224]:\n                      - listitem [ref=e225]: \"OS: macOS 26.2 (arm64)\"\n                      - listitem [ref=e226]:\n                        - text: \"Node:\"\n                        - code [ref=e227]: 22.22.2\n                      - listitem [ref=e228]:\n                        - text: \"Install method: Homebrew/npm global install under\"\n                        - code [ref=e229]: /opt/homebrew/lib/node_modules/openclaw\n                      - listitem [ref=e230]: \"Gateway mode: local loopback\"\n                      - listitem [ref=e231]:\n                        - text: \"Gateway bind:\"\n                        - code [ref=e232]: ws://127.0.0.1:18789\n                      - listitem [ref=e233]: \"Channel in use: Discord (not directly relevant to browser failure, but gateway is otherwise functioning)\"\n                    - separator [ref=e234]\n                    - heading \"Diagnostics collected\" [level=2] [ref=e235]\n                    - heading \"1. Browser config is definitely present\" [level=3] [ref=e236]\n                    - generic [ref=e237]:\n                      - code [ref=e239]: \"120: \\\"browser\\\": { 121- \\\"enabled\\\": true, 122- \\\"defaultProfile\\\": \\\"user\\\", 123- \\\"headless\\\": false, 124- \\\"profiles\\\": { 125- \\\"user\\\": { 126- \\\"driver\\\": \\\"existing-session\\\", 127- \\\"attachOnly\\\": true, 128- \\\"color\\\": \\\"#00AA00\\\" 129- }, 130- \\\"brave\\\": { 131- \\\"driver\\\": \\\"existing-session\\\", 132- \\\"attachOnly\\\": true, 133- \\\"userDataDir\\\": \\\"~/Library/Application Support/BraveSoftware/Brave-Browser\\\", 134- \\\"color\\\": \\\"#FB542B\\\" 135- } 136- } 137- }\"\n                      - button \"Copy\" [ref=e241] [cursor=pointer]:\n                        - img [ref=e242]\n                    - heading \"2. Gateway is healthy\" [level=3] [ref=e245]\n                    - paragraph [ref=e246]:\n                      - code [ref=e247]: openclaw status\n                      - text: \"reports:\"\n                    - list [ref=e248]:\n                      - listitem [ref=e249]: gateway reachable\n                      - listitem [ref=e250]: LaunchAgent running\n                      - listitem [ref=e251]: local loopback healthy\n                    - heading \"3. Browser plugin appears loaded\" [level=3] [ref=e252]\n                    - paragraph [ref=e253]:\n                      - code [ref=e254]: openclaw plugins list\n                      - text: \"shows:\"\n                    - list [ref=e255]:\n                      - listitem [ref=e256]:\n                        - code [ref=e257]: Browser | browser | openclaw | loaded | stock:browser/index.js | 2026.3.28\n                    - paragraph [ref=e258]:\n                      - code [ref=e259]: openclaw plugins inspect browser --json\n                      - text: \"reports that the plugin exposes:\"\n                    - list [ref=e260]:\n                      - listitem [ref=e261]:\n                        - code [ref=e262]: \"gatewayMethods: [\\\"browser.request\\\"]\"\n                      - listitem [ref=e263]:\n                        - code [ref=e264]: \"cliCommands: [\\\"browser\\\"]\"\n                      - listitem [ref=e265]:\n                        - code [ref=e266]: \"services: [\\\"browser-control\\\"]\"\n                    - heading \"4. Gateway logs show method rejection at runtime\" [level=3] [ref=e267]\n                    - paragraph [ref=e268]: \"Relevant log evidence:\"\n                    - generic [ref=e269]:\n                      - code [ref=e271]: \"⇄ res ✗ browser.request 0ms errorCode=INVALID_REQUEST errorMessage=unknown method: browser.request GatewayClientRequestError: unknown method: browser.request\"\n                      - button \"Copy\" [ref=e273] [cursor=pointer]:\n                        - img [ref=e274]\n                    - paragraph [ref=e277]: \"This implies:\"\n                    - list [ref=e278]:\n                      - listitem [ref=e279]: the request reaches the gateway\n                      - listitem [ref=e280]: the gateway does not have the handler registered\n                    - heading \"5. Pairing issue was resolved earlier\" [level=3] [ref=e281]\n                    - paragraph [ref=e282]: There was initially a device scope/pairing issue, but it was approved successfully. After that, the error changed from pairing-related failure to the current method-missing failure.\n                    - paragraph [ref=e283]: So the remaining blocker is not pairing.\n                    - heading \"6. Browser plugin reload attempt did not fix it\" [level=3] [ref=e284]\n                    - paragraph [ref=e285]: \"Attempted sequence:\"\n                    - generic [ref=e286]:\n                      - generic [ref=e287]: openclaw plugins disable browser openclaw gateway restart openclaw plugins enable browser openclaw gateway restart openclaw browser status\n                      - button \"Copy\" [ref=e289] [cursor=pointer]:\n                        - img [ref=e290]\n                    - paragraph [ref=e293]:\n                      - text: \"Result: still fails with\"\n                      - code [ref=e294]: \"unknown method: browser.request\"\n                      - text: .\n                    - separator [ref=e295]\n                    - heading \"Why this appears to be a bug\" [level=2] [ref=e296]\n                    - paragraph [ref=e297]: \"The environment shows an internally inconsistent state:\"\n                    - list [ref=e298]:\n                      - listitem [ref=e299]: browser CLI exists\n                      - listitem [ref=e300]: browser plugin is listed as loaded\n                      - listitem [ref=e301]:\n                        - text: plugin metadata says it provides\n                        - code [ref=e302]: browser.request\n                      - listitem [ref=e303]:\n                        - text: but live gateway rejects\n                        - code [ref=e304]: browser.request\n                        - text: as unknown\n                    - paragraph [ref=e305]: \"This suggests:\"\n                    - list [ref=e306]:\n                      - listitem [ref=e307]: partial plugin load\n                      - listitem [ref=e308]: gateway/plugin registration mismatch\n                      - listitem [ref=e309]: packaging/runtime mismatch\n                      - listitem [ref=e310]: or a regression in bundled browser plugin registration\n                    - separator [ref=e311]\n                    - heading \"Additional notes\" [level=2] [ref=e312]\n                    - paragraph [ref=e313]: \"There is also a separate but related runtime limitation observed in logs:\"\n                    - generic [ref=e314]:\n                      - code [ref=e316]: skipped server \"clickup\" because only stdio MCP servers are supported right now.\n                      - button \"Copy\" [ref=e318] [cursor=pointer]:\n                        - img [ref=e319]\n                    - paragraph [ref=e322]: That is likely unrelated to browser registration, but it confirms that this install/runtime may have capability mismatches between surfaced CLI/config and actual gateway support.\n                    - separator [ref=e323]\n                    - heading \"Suggested investigation areas\" [level=2] [ref=e324]\n                    - list [ref=e325]:\n                      - listitem [ref=e326]: browser plugin registration in gateway startup path\n                      - listitem [ref=e327]: mismatch between plugin registry and gateway-dispatched methods\n                      - listitem [ref=e328]: whether browser plugin is loaded in CLI inventory but not actually activated in gateway runtime\n                      - listitem [ref=e329]:\n                        - text: whether\n                        - code [ref=e330]: browser.enabled=true\n                        - text: path can leave stale gateway method state\n                      - listitem [ref=e331]: whether this is specific to 2026.3.28 on macOS/Homebrew installs\n                    - separator [ref=e332]\n                    - heading \"Minimal commands demonstrating the issue\" [level=2] [ref=e333]\n                    - generic [ref=e334]:\n                      - generic [ref=e335]: openclaw status openclaw plugins list openclaw plugins inspect browser --json openclaw gateway restart openclaw browser status openclaw browser profiles\n                      - button \"Copy\" [ref=e337] [cursor=pointer]:\n                        - img [ref=e338]\n                    - paragraph [ref=e341]: \"Expected:\"\n                    - list [ref=e342]:\n                      - listitem [ref=e343]: browser-specific status/profile output\n                    - paragraph [ref=e344]: \"Actual:\"\n                    - list [ref=e345]:\n                      - listitem [ref=e346]:\n                        - code [ref=e347]: \"GatewayClientRequestError: unknown method: browser.request\"\n                    - heading \"Steps to reproduce\" [level=3] [ref=e348]\n                    - heading \"Reproduction steps\" [level=2] [ref=e349]\n                    - list [ref=e350]:\n                      - listitem [ref=e351]: Ensure OpenClaw gateway is running locally.\n                      - listitem [ref=e352]:\n                        - text: Set browser config in\n                        - code [ref=e353]: ~/.openclaw/openclaw.json\n                        - text: \"similar to:\"\n                    - generic [ref=e354]:\n                      - generic [ref=e355]:\n                        - text: \"{ \\\"browser\\\": { \\\"enabled\\\": true, \\\"defaultProfile\\\":\"\n                        - generic [ref=e356]: \"\\\"user\\\"\"\n                        - text: \", \\\"headless\\\": false, \\\"profiles\\\": { \\\"user\\\": { \\\"driver\\\":\"\n                        - generic [ref=e357]: \"\\\"existing-session\\\"\"\n                        - text: \", \\\"attachOnly\\\": true, \\\"color\\\":\"\n                        - generic [ref=e358]: \"\\\"#00AA00\\\"\"\n                        - text: \"}, \\\"brave\\\": { \\\"driver\\\":\"\n                        - generic [ref=e359]: \"\\\"existing-session\\\"\"\n                        - text: \", \\\"attachOnly\\\": true, \\\"userDataDir\\\":\"\n                        - generic [ref=e360]: \"\\\"~/Library/Application Support/BraveSoftware/Brave-Browser\\\"\"\n                        - text: \", \\\"color\\\":\"\n                        - generic [ref=e361]: \"\\\"#FB542B\\\"\"\n                        - text: \"} } } }\"\n                      - button \"Copy\" [ref=e363] [cursor=pointer]:\n                        - img [ref=e364]\n                    - list [ref=e367]:\n                      - listitem [ref=e368]: \"Restart gateway:\"\n                    - generic [ref=e369]:\n              