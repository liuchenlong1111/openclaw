{"type":"message","id":"302478ee","parentId":"e0939eb3","timestamp":"2026-03-21T14:15:13.089Z","message":{"role":"toolResult","toolCallId":"call_gphtmpseltnfblju9q290yfh","toolName":"exec","content":[{"type":"text","text":"Note: Using default endpoint ID from env: cca86b4a-7106-4336-8a7a-7c3ea7d83400\nCreating video task with ARK endpoint: cca86b4a-7106-4336-8a7a-7c3ea7d83400\nERROR: API call failed: Client error '404 Not Found' for url 'https://ark.cn-beijing.volces.com/api/v3/endpoints/cca86b4a-7106-4336-8a7a-7c3ea7d83400/chat/completions'\nFor more information check: https://developer.mozilla.org/en-US/docs/Web/HTTP/Status/404\nResponse:\n\n(Command exited with code 1)"}],"details":{"status":"completed","exitCode":1,"durationMs":340,"aggregated":"Note: Using default endpoint ID from env: cca86b4a-7106-4336-8a7a-7c3ea7d83400\nCreating video task with ARK endpoint: cca86b4a-7106-4336-8a7a-7c3ea7d83400\nERROR: API call failed: Client error '404 Not Found' for url 'https://ark.cn-beijing.volces.com/api/v3/endpoints/cca86b4a-7106-4336-8a7a-7c3ea7d83400/chat/completions'\nFor more information check: https://developer.mozilla.org/en-US/docs/Web/HTTP/Status/404\nResponse:\n\n(Command exited with code 1)","cwd":"/Users/liuchenglong/.openclaw/workspace"},"isError":false,"timestamp":1774102513087}}
{"type":"message","id":"00b869c0","parentId":"302478ee","timestamp":"2026-03-21T14:15:21.973Z","message":{"role":"assistant","content":[{"type":"text","text":"哦！404 说明端点路径不对，应该是 `/v3/chat/completions` 而不是带端点ID的路径？让我换路径试试：\n\n\n\n\n\n\n"},{"type":"toolCall","id":"call_u2z85epfcg43p8j608dmqu23","name":"write","arguments":{"path":"/Users/liuchenglong/.openclaw/workspace/skills/video-gen/scripts/generate_video_ark_v2.py","content":"#!/usr/bin/env python3\n\"\"\"\nVideo Generation Script using Doubao Seedance on Volcengine ARK Platform\nAlternative ARK endpoint format\n\"\"\"\nimport os\nimport sys\nimport json\nimport time\nimport base64\nimport httpx\nfrom pathlib import Path\n\n# Environment variables:\n# - ARK_API_KEY: Your Volcengine ARK API Key\n# - ARK_ENDPOINT_ID: Model endpoint ID\n\nARK_API_KEY = os.environ.get(\"ARK_API_KEY\", os.environ.get(\"VIDEO_GEN_API_KEY\", \"\"))\nARK_ENDPOINT_ID = os.environ.get(\"ARK_ENDPOINT_ID\", \"cca86b4a-7106-4336-8a7a-7c3ea7d83400\")\n\n# For ARK, the endpoint is:\n# https://ark.cn-beijing.volces.com/api/v3/chat/completions\n# The model field is: endpoint_id\nARK_URL = \"https://ark.cn-beijing.volces.com/api/v3/chat/completions\"\n\ndef create_video_task_ark(\n    prompt: str,\n    mode: str = \"text_to_video\",\n    first_frame_path: str = None,\n    aspect_ratio: str = \"16:9\",\n    duration: int = 5,\n) -> dict:\n    \"\"\"Create video generation task using ARK endpoint\"\"\"\n    \n    if not ARK_API_KEY:\n        print(\"ERROR: ARK_API_KEY environment variable is required\", file=sys.stderr)\n        sys.exit(1)\n    \n    headers = {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": f\"Bearer {ARK_API_KEY}\",\n    }\n    \n    # Build the content according to Seedance format\n    content = []\n    \n    # Add text prompt\n    content.append({\n        \"type\": \"text\",\n        \"text\": prompt\n    })\n    \n    # Add first frame if provided\n    if first_frame_path and os.path.exists(first_frame_path):\n        with open(first_frame_path, \"rb\") as f:\n            img_b64 = base64.b64encode(f.read()).decode()\n            content.append({\n                \"type\": \"image_url\",\n                \"image_url\": {\n                    \"url\": f\"data:image/jpeg;base64,{img_b64}\"\n                }\n            })\n    \n    payload = {\n        \"model\": ARK_ENDPOINT_ID,\n        \"messages\": [\n            {\n                \"role\": \"user\",\n                \"content\": content\n            }\n        ],\n        \"parameters\": {\n            \"aspect_ratio\": aspect_ratio,\n            \"duration\": duration\n        }\n    }\n    \n    print(f\"Creating video task with ARK endpoint: {ARK_ENDPOINT_ID}\", file=sys.stderr)\n    \n    try:\n        with httpx.Client(timeout=httpx.Timeout(120.0)) as client:\n            response = client.post(ARK_URL, headers=headers, json=payload)\n            response.raise_for_status()\n            result = response.json()\n    except Exception as e:\n        print(f\"ERROR: API call failed: {e}\", file=sys.stderr)\n        if hasattr(e, 'response') and e.response is not None:\n            print(f\"Response: {e.response.text}\", file=sys.stderr)\n        sys.exit(1)\n    \n    return result\n\n\nif __name__ == \"__main__\":\n    import argparse\n    parser = argparse.ArgumentParser(description=\"Generate video with Doubao Seedance (Volcengine ARK format v2)\")\n    parser.add_argument(\"prompt\", help=\"Text prompt for video generation\")\n    parser.add_argument(\"--first-frame\", help=\"First frame image file path\")\n    parser.add_argument(\"--aspect-ratio\", default=\"16:9\", help=\"Aspect ratio\")\n    parser.add_argument(\"--duration\", type=int, default=5, help=\"Duration in seconds\")\n    parser.add_argument(\"--output\", \"-o\", help=\"Output video file path\")\n    args = parser.parse_args()\n    \n    result = create_video_task_ark(\n        prompt=args.prompt,\n        first_frame_path=args.first_frame,\n        aspect_ratio=args.aspect_ratio,\n        duration=args.duration,\n    )\n    \n    print(json.dumps(result, indent=2, ensure_ascii=False))\n"}}],"api":"anthropic-messages","provider":"custom-ark-cn-beijing-volces-com","model":"ark-code-latest","usage":{"input":913,"output":1065,"cacheRead":33592,"cacheWrite":0,"totalTokens":35570,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774102513090}}
