e144]\n                  - row \"image_to_video_base64 图生视频（Base64） prompt + --first-frame 路径/base64\" [ref=e145]:\n                    - cell \"image_to_video_base64\" [ref=e146]:\n                      - code [ref=e147]: image_to_video_base64\n                    - cell \"图生视频（Base64）\" [ref=e148]\n                    - cell \"prompt + --first-frame 路径/base64\" [ref=e149]\n                  - row \"audio_video_first_frame 有声视频-首帧 prompt + --first-frame + --audio\" [ref=e150]:\n                    - cell \"audio_video_first_frame\" [ref=e151]:\n                      - code [ref=e152]: audio_video_first_frame\n                    - cell \"有声视频-首帧\" [ref=e153]\n                    - cell \"prompt + --first-frame + --audio\" [ref=e154]\n                  - row \"audio_video_first_last_frame 有声视频-首尾帧 prompt + --first-frame + --last-frame + --audio\" [ref=e155]:\n                    - cell \"audio_video_first_last_frame\" [ref=e156]:\n                      - code [ref=e157]: audio_video_first_last_frame\n                    - cell \"有声视频-首尾帧\" [ref=e158]\n                    - cell \"prompt + --first-frame + --last-frame + --audio\" [ref=e159]\n                  - row \"seedance_lite_reference Seedance-Lite 参考图 prompt + --reference-image\" [ref=e160]:\n                    - cell \"seedance_lite_reference\" [ref=e161]:\n                      - code [ref=e162]: seedance_lite_reference\n                    - cell \"Seedance-Lite 参考图\" [ref=e163]\n                    - cell \"prompt + --reference-image\" [ref=e164]\n              - heading \"可用模型\" [level=2] [ref=e165]\n              - list [ref=e166]:\n                - listitem [ref=e167]:\n                  - code [ref=e168]: doubao-seedance-1.5\n                  - text: — 完整版（默认）\n                - listitem [ref=e169]:\n                  - code [ref=e170]: seedance-lite\n                  - text: — 轻量版\n              - heading \"使用方法\" [level=2] [ref=e171]\n              - heading \"文生视频\" [level=3] [ref=e172]\n              - code [ref=e174]: export VIDEO_GEN_API_KEY=\"your-api-key\" python3 scripts/generate_video.py \"一只可爱的小猫在草地上奔跑，阳光明媚，慢动作\" \\ --mode text_to_video \\ --output cat_running.mp4\n              - heading \"图生视频\" [level=3] [ref=e175]\n              - code [ref=e177]: python3 scripts/generate_video.py \"让图片中的人物转头微笑\" \\ --mode image_to_video \\ --first-frame \"https://example.com/image.jpg\" \\ --output person_smile.mp4\n              - heading \"图生视频（Base64）\" [level=3] [ref=e178]\n              - code [ref=e180]: python3 scripts/generate_video.py \"让图片动起来\" \\ --mode image_to_video_base64 \\ --first-frame ./input_image.png \\ --output animated.mp4\n              - heading \"有声视频（首帧）\" [level=3] [ref=e181]\n              - code [ref=e183]: python3 scripts/generate_video.py \"人物开口说话，声音洪亮\" \\ --mode audio_video_first_frame \\ --first-frame ./portrait.jpg \\ --audio \\ --output talking.mp4\n              - heading \"有声视频（首尾帧）\" [level=3] [ref=e184]\n              - code [ref=e186]: python3 scripts/generate_video.py \"人物从左转头到右\" \\ --mode audio_video_first_last_frame \\ --first-frame ./left.jpg \\ --last-frame ./right.jpg \\ --audio \\ --output turn_head.mp4\n              - heading \"Seedance-Lite 参考图\" [level=3] [ref=e187]\n              - code [ref=e189]: python3 scripts/generate_video.py \"参考图片风格生成视频\" \\ --mode seedance_lite_reference \\ --reference-image ./style_ref.jpg \\ --output styled_video.mp4\n              - heading \"工作流程\" [level=2] [ref=e190]\n              - list [ref=e191]:\n                - listitem [ref=e192]:\n                  - strong [ref=e193]: 理解需求\n                  - text: ：分析用户的视频需求，确定生成模式\n                - listitem [ref=e194]:\n                  - strong [ref=e195]: 选择模式\n                  - text: ：文生视频、图生视频、有声视频等\n                - listitem [ref=e196]:\n                  - strong [ref=e197]: 优化提示词\n                  - text: ：将用户描述扩展为详细的视频描述\n                - listitem [ref=e198]:\n                  - strong [ref=e199]: 执行脚本\n                  - text: ：调用\n                  - code [ref=e200]: scripts/generate_video.py\n                  - text: 生成视频\n                - listitem [ref=e201]:\n                  - strong [ref=e202]: 等待完成\n                  - text: ：视频生成通常需要几分钟\n                - listitem [ref=e203]:\n                  - strong [ref=e204]: 上传视频\n                  - text: ：上传到飞书获取 file_key\n                - listitem [ref=e205]:\n                  - strong [ref=e206]: 发送视频\n                  - text: ：使用\n                  - code [ref=e207]: message\n                  - text: 工具发送视频\n              - heading \"飞书视频上传\" [level=2] [ref=e208]\n              - code [ref=e210]: \"import requests # 获取 token（使用飞书 app_id 和 app_secret） resp = requests.post( \\\"https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal\\\", json={\\\"app_id\\\": \\\"YOUR_APP_ID\\\", \\\"app_secret\\\": \\\"YOUR_APP_SECRET\\\"} ) token = resp.json()[\\\"tenant_access_token\\\"] # 上传视频 with open(\\\"video.mp4\\\", \\\"rb\\\") as f: resp = requests.post( \\\"https://open.feishu.cn/open-apis/im/v1/files\\\", headers={\\\"Authorization\\\": f\\\"Bearer {token}\\\"}, files={\\\"file\\\": (\\\"video.mp4\\\", f, \\\"video/mp4\\\")}, data={\\\"file_type\\\": \\\"mp4\\\"} ) file_key = resp.json()[\\\"data\\\"][\\\"file_key\\\"] # 发送视频 # 使用 message 工具: {\\\"file_key\\\": \\\"<file_key>\\\"}\"\n              - heading \"提示词技巧\" [level=2] [ref=e211]\n              - list [ref=e212]:\n                - listitem [ref=e213]:\n                  - strong [ref=e214]: 描述动作\n                  - text: ：清晰描述主体运动、镜头运动\n                - listitem [ref=e215]:\n                  - strong [ref=e216]: 时间感\n                  - text: ：快/慢动作、延时、瞬间\n                - listitem [ref=e217]:\n                  - strong [ref=e218]: 氛围感\n                  - text: ：光线、天气、情绪\n                - listitem [ref=e219]:\n                  - strong [ref=e220]: 镜头语言\n                  - text: ：推/拉/摇/移、特写/远景\n              - heading \"参数说明\" [level=2] 