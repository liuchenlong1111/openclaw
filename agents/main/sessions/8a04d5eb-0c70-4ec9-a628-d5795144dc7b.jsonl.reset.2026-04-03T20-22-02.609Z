aw/openclaw/commits/b894ca6702c8c0b26a14748a18154c81f406bb1f\",\n    \"html_url\": \"https://github.com/openclaw/openclaw/commit/b894ca6702c8c0b26a14748a18154c81f406bb1f\",\n    \"comments_url\": \"https://api.github.com/repos/openclaw/openclaw/commits/b894ca6702c8c0b26a14748a18154c81f406bb1f/comments\",\n    \"author\": {\n      \"login\": \"al3mart\",\n      \"id\": 11448715,\n      \"node_id\": \"MDQ6VXNlcjExNDQ4NzE1\",\n      \"avatar_url\": \"https://avatars.githubusercontent.com/u/11448715?v=4\",\n      \"gravatar_id\": \"\",\n      \"url\": \"https://api.github.com/users/al3mart\",\n      \"html_url\": \"https://github.com/al3mart\",\n      \"followers_url\": \"https://api.github.com/users/al3mart/followers\",\n      \"following_url\": \"https://api.github.com/users/al3mart/following{/other_user}\",\n      \"gists_url\": \"https://api.github.com/users/al3mart/gists{/gist_id}\",\n      \"starred_url\": \"https://api.github.com/users/al3mart/starred{/owner}{/repo}\",\n      \"subscriptions_url\": \"https://api.github.com/users/al3mart/subscriptions\",\n      \"organizations_url\": \"https://api.github.com/users/al3mart/orgs\",\n      \"repos_url\": \"https://api.github.com/users/al3mart/repos\",\n      \"events_url\": \"https://api.github.com/users/al3mart/events{/privacy}\",\n      \"received_events_url\": \"https://api.github.com/users/al3mart/received_events\",\n      \"type\": \"User\",\n      \"user_view_type\": \"public\",\n      \"site_admin\": false\n    },\n    \"committer\": {\n      \"login\": \"web-flow\",\n      \"id\": 19864447,\n      \"node_id\": \"MDQ6VXNlcjE5ODY0NDQ3\",\n      \"avatar_url\": \"https://avatars.githubusercontent.com/u/19864447?v=4\",\n      \"gravatar_id\": \"\",\n      \"url\": \"https://api.github.com/users/web-flow\",\n      \"html_url\": \"https://github.com/web-flow\",\n      \"followers_url\": \"https://api.github.com/users/web-flow/followers\",\n      \"following_url\": \"https://api.github.com/users/web-flow/following{/other_user}\",\n      \"gists_url\": \"https://api.github.com/users/web-flow/gists{/gist_id}\",\n      \"starred_url\": \"https://api.github.com/users/web-flow/starred{/owner}{/repo}\",\n      \"subscriptions_url\": \"https://api.github.com/users/web-flow/subscriptions\",\n      \"organizations_url\": \"https://api.github.com/users/web-flow/orgs\",\n      \"repos_url\": \"https://api.github.com/users/web-flow/repos\",\n      \"events_url\": \"https://api.github.com/users/web-flow/events{/privacy}\",\n      \"received_events_url\": \"https://api.github.com/users/web-flow/received_events\",\n      \"type\": \"User\",\n      \"user_view_type\": \"public\",\n      \"site_admin\": false\n    },\n    \"parents\": [\n      {\n        \"sha\": \"739ed1bf2944066b1ed9927ae0338dca7f42106d\",\n        \"url\": \"https://api.github.com/repos/openclaw/openclaw/commits/739ed1bf2944066b1ed9927ae0338dca7f42106d\",\n        \"html_url\": \"https://github.com/openclaw/openclaw/commit/739ed1bf2944066b1ed9927ae0338dca7f42106d\"\n      }\n    ]\n  },\n  {\n    \"sha\": \"739ed1bf2944066b1ed9927ae0338dca7f42106d\",\n    \"node_id\": \"C_kwDOQb6kR9oAKDczOWVkMWJmMjk0NDA2NmIxZWQ5OTI3YWUwMzM4ZGNhN2Y0MjEwNmQ\",\n    \"commit\": {\n      \"author\": {\n        \"name\": \"Hyojin Kwak\",\n        \"email\": \"hyojinksd@gmail.com\",\n        \"date\": \"2026-04-02T23:27:13Z\"\n      },\n      \"committer\": {\n        \"name\": \"GitHub\",\n        \"email\": \"noreply@github.com\",\n        \"date\": \"2026-04-02T23:27:13Z\"\n      },\n      \"message\": \"fix(msteams): preserve channel reply threading in proactive fallback (#55198)\\n\\nWhen a thread reply's turn context is revoked and falls back to proactive messaging, the normalized conversation ID lost the thread suffix, causing replies to land in the channel root instead of the original thread.\\n\\nReconstructs the threaded conversation ID (`;messageid=<activityId>`) for channel conversations in the proactive fallback path, while correctly leaving group chat conversations flat.\\n\\nFixes #27189\\n\\nThanks @hyojin\",\n      \"tree\": {\n        \"sha\": \"50f5547f1399104f81c20f020684c134fe4a213a\",\n        \"url\": \"https://api.github.com/repos/openclaw/openclaw/git/trees/50f5547f1399104f81c20f020684c134fe4a213a\"\n      },\n      \"url\": \"https://api.github.com/repos/openclaw/openclaw/git/commits/739ed1bf2944066b1ed9927ae0338dca7f42106d\",\n      \"comment_count\": 0,\n      \"verification\": {\n        \"verified\": true,\n        \"reason\": \"valid\",\n        \"signature\": \"-----BEGIN PGP SIGNATURE-----\\n\\nwsFcBAABCAAQBQJpzvtRCRC1aQ7uu5UhlAAA/KcQAHgxtb1aSySsIfj/AKZ6G02Q\\nXPuQHjBNvKcPWBKgVVV6ZdTCDIELng1eWtb7IKKFAgrGNdDvxkLcewXiSLaM66eJ\\nlh0vEgTWyLN8VqY1IMPAU81PnyWv9dvJPmjKVN5xtk6pjLtGoNM+Tw80lxnN/bhG\\nVwluOkBuIL/xNU9mtVKef/pt+oNiox3sSJ6flNK9IL68alA2eWImVB1eFyTn0d4d\\nf+dvVTFb4Ebyznw6NlvRf9qi2YprWgt1DYFy3I2UWss7/usgk15Ng7dgnawOqmtW\\n+Eq4H/jXffUQgPWy/H2CGzWEEFd4coBJItZ6qgz9pbmT5ekwVKZMPYwERKrfx4Y1\\n9fgt7Kak6seyIyZga9/RNHLGevd/Tw2NdKGsKJ4XqnFvT6cMl5q38fEY0NBUanws\\ngWRtK6gsTCiS7GG1+hxKrB/2CqLgnU4DBjRTPRUD+Hr+w2Fwr+Cn11WDIewpeBRk\\nZF0ncMDkT5olGftnh0zJVcl419JRep+yNzqwhzfw6w2YYMfP66sEXqRLCzyeZNpM\\nAKwAEbkRCJX7hZjYDz/FNH+0V/R1+068DsUGIBj+hwgfEVRDyzmHh3VC6ncikAT2\\nWMckQW50sgkaeCKH2gBXAxwT4C6VUQG7txKoooqVeVT/lfYPPCSxH4VkZuNaFyRB\\nxfEZmz1m1zpl9Obd/OUr\\n=ca0j\\n-----END PGP SIGNATURE-----\\n\",\n        \"payload\": \"tree 50f5547f1399104f81c20f020684c134fe4a213a\\nparent ed8d5b3797915a9a91df4343dcf0fb4247ccd889\\nauthor Hyojin Kwak <hyojinksd@gmail.com> 1775172433 +0900\\ncommitter GitHub <noreply@github.com> 1775172433 -0500\\n\\nfix(msteams): preserve channel reply threading in proactive fallback (#55198)\\n\\nWhen a thread reply's turn context is revoked and falls back to proactive messaging, the normalized conversation ID lost the thread suffix, causing replies to land in the channel root instead of the original thread.\\n\\nReconstructs the threaded conversation ID (`;messageid=<activityId>`) for channel conversations in the proactive fallback path, while correctly leaving group chat conversations flat.\\n\\nFixes #27189\\n\\nThanks @hyojin\",\n        \"verified_at\": \"2026-04-02T23:27:14Z\"\n      }\n    },\n    \"url\": \"https://api.github.com/repos/openclaw/openclaw/commits/739ed1bf2944066b1ed9927ae0338dca7f42106d\",\n    \"html_url\": \"https://github.com/openclaw/openclaw/commit/739ed1bf2944066b1ed9927ae0338dca7f42106d\",\n    \"comments_url\": \"https://api.github.com/repos/openclaw/openclaw/commits/739ed1bf2944066b1ed9927ae0338dca7f42106d/comments\",\n    \"author\": {\n      \"login\": \"hyojin\",\n      \"id\": 3413183,\n      \"node_id\": \"MDQ6VXNlcjM0MTMxODM=\",\n      \"avatar_url\": \"https://avatars.githubusercontent.com/u/3413183?v=4\",\n      \"gravatar_id\": \"\",\n      \"url\": \"https://api.github.com/users/hyojin\",\n      \"html_url\": \"https://github.com/hyojin\",\n      \"followers_url\": \"https://api.github.com/users/hyojin/followers\",\n      \"following_url\": \"https://api.github.com/users/hyojin/following{/other_user}\",\n      \"gists_url\": \"https://api.github.com/users/hyojin/gists{/gist_id}\",\n      \"starred_url\": \"https://api.github.com/users/hyojin/starred{/owner}{/repo}\",\n      \"subscriptions_url\": \"https://api.github.com/users/hyojin/subscriptions\",\n      \"organizations_url\": \"https://api.github.com/users/hyojin/orgs\",\n      \"repos_url\": \"https://api.github.com/users/hyojin/repos\",\n      \"events_url\": \"https://api.github.com/users/hyojin/events{/privacy}\",\n      \"received_events_url\": \"https://api.github.com/users/hyojin/received_events\",\n      \"type\": \"User\",\n      \"user_view_type\": \"public\",\n      \"site_admin\": false\n    },\n    \"committer\": {\n      \"login\": \"web-flow\",\n      \"id\": 19864447,\n      \"node_id\": \"MDQ6VXNlcjE5ODY0NDQ3\",\n      \"avatar_url\": \"https://avatars.githubusercontent.com/u/19864447?v=4\",\n      \"gravatar_id\": \"\",