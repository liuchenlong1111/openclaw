{"type":"message","id":"e09eb6c3","parentId":"ad57f7cf","timestamp":"2026-03-18T15:40:56.997Z","message":{"role":"toolResult","toolCallId":"read:31","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nGenerate quiz questions from extracted text content.\nSupports multiple question types with formatted output.\n\"\"\"\n\nimport sys\nimport argparse\nimport json\nimport re\n\ndef generate_questions(content, count=6, types=None):\n    \"\"\"\n    Generate quiz questions from content.\n    This is a template function - in practice, this would call an LLM API.\n    \"\"\"\n    if types is None:\n        types = ['single', 'multiple', 'uncertain', 'judgment', 'fill', 'short']\n    \n    # Map type names to Chinese labels\n    type_labels = {\n        'single': '单选',\n        'multiple': '多选',\n        'uncertain': '不定项',\n        'judgment': '判断',\n        'fill': '填空',\n        'short': '简答'\n    }\n    \n    # For now, return a template showing the expected format\n    # In real implementation, this would use LLM to generate actual questions\n    \n    questions = []\n    \n    # Example templates for each type\n    templates = {\n        'single': {\n            'template': '''{num}.[{type}]在文档描述的{topic}中，{question}？\nA. {option_a}\nB. {option_b}\nC. {option_c}\nD. {option_d}\n答案：{answer}\n解析：{explanation}\n题目难度：{difficulty}''',\n            'example': {\n                'topic': '测试流程',\n                'question': '用于存储测试数据并在最后生成报告的变量最初是通过哪个作用域尝试传递的',\n                'option_a': 'self实例变量',\n                'option_b': 'local局部变量',\n                'option_c': 'global全局变量',\n                'option_d': 'class类属性',\n                'answer': 'A',\n                'explanation': '文中提到使用self.test_demo来传递数据，并在teardown阶段发现该实例变量无法保留数据，说明最初是通过self实例作用域尝试传递的。',\n                'difficulty': '中'\n            }\n        },\n        'multiple': {\n            'template': '''{num}.[{type}]以下哪些{question}？\nA. {option_a}\nB. {option_b}\nC. {option_c}\nD. {option_d}\n答案：{answer}\n解析：{explanation}\n题目难度：{difficulty}''',\n            'example': {\n                'question': '操作是为了解决测试数据未能成功写入报告的问题而被尝试过的',\n                'option_a': '将数据打印逻辑从tearDown移到setUp中',\n                'option_b': '使用global关键字声明全局变量',\n                'option_c': '将test_demo设置为类属性',\n                'option_d': '在tearDown class阶段调用HTML模板生成器',\n                'answer': 'BCD',\n                'explanation': '文中尝试了global声明（但失败）、将test_demo作为类属性处理、以及在teardown class中调用HTML模板；而打印逻辑是从teardown往上移，非移到setUp。',\n                'difficulty': '中'\n            }\n        },\n        'uncertain': {\n            'template': '''{num}.[{type}]{question}？\nA. {option_a}\nB. {option_b}\nC. {option_c}\nD. {option_d}\n答案：{answer}\n解析：{explanation}\n题目难度：{difficulty}''',\n            'example': {\n                'question': '关于测试报告中样式未生效的原因，下列说法正确的是',\n                'option_a': '使用的十六进制颜色编码格式错误，应为0x前缀',\n                'option_b': '浏览器不再支持早期的十六进制颜色写法',\n                'option_c': '使用英文颜色单词（如Red、Green）可以正确显示',\n                'option_d': '样式设置应在断言之前完成',\n                'answer': 'BC',\n                'explanation': '文中指出可能因浏览器不支持旧式写法导致颜色未生效，最终改用英文单词\"Red\"\"Green\"解决了问题；并未提及0x格式正确性或断言顺序影响。',\n                'difficulty': '中'\n            }\n        },\n        'judgment': {\n            'template': '''{num}.[{type}]{statement}。\n答案：{answer}\n解析：{explanation}\n题目难度：{difficulty}''',\n            'example': {\n                'statement': '在测试执行过程中，每次运行test百度时，self.test_demo都被重新初始化为空列表，导致数据无法累计',\n                'answer': '错误',\n                'explanation': '文档中显示数据确实被追加到self.test_demo中并能打印出三组，但在teardown时却为空，说明不是初始化问题而是传递失效。',\n                'difficulty': '中'\n            }\n        },\n        'fill': {\n            'template': '''{num}.[{type}]{question}\n填空数：{fill_count}\n答案形式：{answer_format}\n参考答案1：{answer}\n解析：{explanation}\n题目难度：{difficulty}''',\n            'example': {\n                'question': '为使测试数据能在teardown阶段被正确读取并写入报告，最终采用的方法是将test_demo设置为__，从而确保其在整个测试周期中可被访问。',\n                'fill_count': '1',\n                'answer_format': '完全一致',\n                'answer': '类属性',\n                'explanation': '文档中通过将test_demo作为类属性而非实例属性，解决了跨方法访问的数据丢失问题。',\n                'difficulty': '中'\n            }\n        },\n        'short': {\n            'template': '''{num}.[{type}]{question}？\n参考答案：{answer}\n解析：{explanation}\n题目难度：{difficulty}''',\n            'example': {\n                'question': '请简述为什么最初使用self.test_demo传递测试数据在teardown阶段会失败，以及最终是如何解决这个问题的',\n                'answer': '最初使用self.test_demo作为实例变量，在teardown阶段由于WebDriver关闭导致实例状态不可达，数据虽在运行期间存在但无法在最终阶段获取。解决方案是将test_demo改为类属性，使其脱离单个实例生命周期，从而在整个测试类中持久可用，并在teardown class阶段成功读取数据生成报告。',\n                'explanation': '该问题涉及对象生命周期与作用域的理解，以及如何通过调整变量层级来实现跨阶段数据共享。',\n                'difficulty': '中'\n            }\n        }\n    }\n    \n    # Generate placeholder questions\n    type_list = list(types)\n    for i in range(min(count, len(type_list))):\n        q_type = type_list[i % len(type_list)]\n        if q_type in templates:\n            template = templates[q_type]['template']\n            example = templates[q_type]['example']\n            \n            question_text = template.format(\n                num=i+1,\n                type=type_labels.get(q_type, q_type),\n                **example\n            )\n            questions.append(question_text)\n    \n    return \"\\n\\n\".join(questions)\n\ndef main():\n    parser = argparse.ArgumentParser(description='Generate quiz questions from text content')\n    parser.add_argument('--input', '-i', required=True, help='Input text file path')\n    parser.add_argument('--count', '-c', type=int, default=6, help='Number of questions to generate')\n    parser.add_argument('--types', '-t', default='single,multiple,uncertain,judgment,fill,short',\n                        help='Comma-separated list of question types')\n    parser.add_argument('--output', '-o', help='Output file (default: stdout)')\n    args = parser.parse_args()\n    \n    # Read input content\n    try:\n        with open(args.input, 'r', encoding='utf-8') as f:\n            content = f.read()\n    except Exception as e:\n        print(f\"Error reading input file: {e}\", file=sys.stderr)\n        sys.exit(1)\n    \n    # Parse question types\n    types = [t.strip() for t in args.types.split(',')]\n    \n    # Generate questions\n    questions = generate_questions(content, args.count, types)\n    \n    # Output\n    if args.output:\n        with open(args.output, 'w', encoding='utf-8') as f:\n            f.write(questions)\n        print(f\"Questions saved to {args.output}\", file=sys.stderr)\n    else:\n        print(questions)\n\nif __name__ == '__main__':\n    main()\n"}],"isError":false,"timestamp":1773848456995}}
{"type":"message","id":"6744acf1","parentId":"e09eb6c3","timestamp":"2026-03-18T15:41:36.827Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"write:32","name":"write","arguments":{"content":"#!/usr/bin/env python3\n\"\"\"\nGenerate quiz questions from extracted text content using LLM API.\nSupports multiple question types with formatted output.\n\"\"\"\n\nimport sys\nimport argparse\nimport os\nimport json\n\ntry:\n    from openai import OpenAI\nexcept ImportError:\n    print(\"Error: openai not installed. Run: pip install openai\", file=sys.stderr)\n    sys.exit(1)\n\n# Type mapping\ntype_labels = {\n    'single': '单选',\n    'multiple': '多选',\n    'uncertain': '不定项',\n    'judgment': '判断',\n    'fill': '填空',\n    'short': '简答'\n}\n\ndef get_llm_client(provider='openai', api_key=None, base_url=None):\n    \"\"\"Get LLM client for different providers\"\"\"\n    if provider == 'openai':\n        key = api_key or os.environ.get('OPENAI_API_KEY')\n        if not key:\n            raise ValueError(\"OpenAI API key required. Set OPENAI_API_KEY env var or use --api-key\")\n        return OpenAI(api_key=key, base_url=base_url)\n    \n    elif provider == 'moonshot':\n        key = api_key or os.environ.get('MOONSHOT_API_KEY')\n        if not key:\n            raise ValueError(\"Moonshot API key required. Set MOONSHOT_API_KEY env var or use --api-key\")\n        return OpenAI(api_key=key, base_url=base_url or \"https://api.moonshot.cn/v1\")\n    \n    elif provider == 'deepseek':\n        key = api_key or os.environ.get('DEEPSEEK_API_KEY')\n        if not key:\n            raise ValueError(\"DeepSeek API key required. Set DEEPSEEK_API_KEY env var or use --api-key\")\n        return OpenAI(api_key=key, base_url=base_url or \"https://api.deepseek.com/v1\")\n    \n    else:\n        raise ValueError(f\"Unknown provider: {provider}\")\n\ndef build_prompt(content, count, types):\n    \"\"\"Build prompt for LLM\"\"\"\n    type_names = [type_labels.get(t, t) for t in types]\n    type_str = \"、\".join(type_names)\n    \n    prompt = f\"\"\"请根据以下文档内容生成 {count} 道考试题目。\n\n## 文档内容\n{content}\n\n## 要求\n1. 题目类型包括：{type_str}\n2. 每道题必须包含：题目、答案、解析、难度\n3. 单选/多选/不定项题必须提供4个选项（A、B、C、D）\n4. 填空题用 __ 表示填空位置，并注明填空数和答案形式\n5. 解析必须说明答案在原文中的出处\n6. 难度分为：易、中、难\n7. 题目序号从1开始连续编号\n\n## 输出格式示例\n\n1.[单选]题目内容？\nA. 选项A\nB. 选项B\nC. 选项C\nD. 选项D\n答案：A\n解析：解析内容，说明在原文中的依据\n题目难度：中\n\n2.[多选]题目内容？\nA. 选项A\nB. 选项B\nC. 选项C\nD. 选项D\n答案：BCD\n解析：解析内容，说明在原文中的依据\n题目难度：中\n\n3.[不定项]题目内容？\nA. 选项A\nB. 选项B\nC. 选项C\nD. 选项D\n答案：BC\n解析：解析内容，说明在原文中的依据\n题目难度：中\n\n4.[判断]题目陈述内容。\n答案：正确/错误\n解析：解析内容，说明在原文中的依据\n题目难度：中\n\n5.[填空]题目内容，填空处用__表示。\n填空数：1\n答案形式：完全一致\n参考答案1：答案内容\n解析：解析内容，说明在原文中的依据\n题目难度：中\n\n6.[简答]题目内容？\n参考答案：参考答案内容\n解析：解析内容，说明在原文中的依据\n题目难度：中\n\n请严格按照上述格式生成 {count} 道题目，确保格式完全正确。\"\"\"\n    \n    return prompt\n\ndef generate_questions(content, count=6, types=None, provider='openai', api_key=None, model=None):\n    \"\"\"Generate quiz questions using LLM API\"\"\"\n    if types is None:\n        types = ['single', 'multiple', 'uncertain', 'judgment', 'fill', 'short']\n    \n    # Get client\n    client = get_llm_client(provider, api_key)\n    \n    # Build prompt\n    prompt = build_prompt(content, count, types)\n    \n    # Set default model based on provider\n    if model is None:\n        if provider == 'openai':\n            model = 'gpt-4o'\n        elif provider == 'moonshot':\n            model = 'moonshot-v1-8k'\n        elif provider == 'deepseek':\n            model = 'deepseek-chat'\n    \n    try:\n        response = client.chat.completions.create(\n            model=model,\n            messages=[\n                {\"role\": \"system\", \"content\": \"你是一个专业的考试题目生成助手。请根据提供的文档内容生成格式规范的考试题目。\"},\n                {\"role\": \"user\", \"content\": prompt}\n            ],\n            temperature=0.7,\n            max_tokens=4000\n        )\n        \n        return response.choices[0].message.content\n    \n    except Exception as e:\n        print(f\"Error calling LLM API: {e}\", file=sys.stderr)\n        sys.exit(1)\n\ndef main():\n    parser = argparse.ArgumentParser(description='Generate quiz questions from text content using LLM')\n    parser.add_argument('--input', '-i', required=True, help='Input text file path')\n    parser.add_argument('--count', '-c', type=int, default=6, help='Number of questions to generate')\n    parser.add_argument('--types', '-t', default='single,multiple,uncertain,judgment,fill,short',\n                        help='Comma-separated list of question types: single,multiple,uncertain,judgment,fill,short')\n    parser.add_argument('--output', '-o', help='Output file (default: stdout)')\n    parser.add_argument('--provider', '-p', default='openai', \n                        choices=['openai', 'moonshot', 'deepseek'],\n                        help='LLM provider (default: openai)')\n    parser.add_argument('--api-key', '-k', help='API key for the provider')\n    parser.add_argument('--model', '-m', help='Model name (provider-specific)')\n    args = parser.parse_args()\n    \n    # Read input content\n    try:\n        with open(args.input, 'r', encoding='utf-8') as f:\n            content = f.read()\n    except Exception as e:\n        print(f\"Error reading input file: {e}\", file=sys.stderr)\n        sys.exit(1)\n    \n    # Check content length\n    if len(content) > 15000:\n        print(\"Warning: Content is very long. Truncating to 15000 characters.\", file=sys.stderr)\n        content = content[:15000] + \"...\"\n    \n    # Parse question types\n    types = [t.strip() for t in args.types.split(',')]\n    \n    # Validate types\n    valid_types = set(type_labels.keys())\n    invalid_types = set(types) - valid_types\n    if invalid_types:\n        print(f\"Error: Invalid question types: {invalid_types}\", file=sys.stderr)\n        print(f\"Valid types: {valid_types}\", file=sys.stderr)\n        sys.exit(1)\n    \n    # Generate questions\n    print(f\"Generating {args.count} questions using {args.provider}...\", file=sys.stderr)\n    questions = generate_questions(\n        content, \n        args.count, \n        types, \n        provider=args.provider,\n        api_key=args.api_key,\n        model=args.model\n    )\n    \n    # Output\n    if args.output:\n        with open(args.output, 'w', encoding='utf-8') as f:\n            f.write(questions)\n        print(f\"Questions saved to {args.output}\", file=sys.stderr)\n    else:\n        print(questions)\n\nif __name__ == '__main__':\n    main()\n","file_path":"/Users/liuchenglong/.openclaw/workspace/skills/multimodal-quiz-generator/scripts/generate_quiz.py"}}],"api":"openai-completions","provider":"moonshot","model":"kimi-k2.5","usage":{"input":2081,"output":2000,"cacheRead":33792,"cacheWrite":0,"totalTokens":37873,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773848456999}}
