tionAlreadyAdded?: boolean;\n557-}\n558-\n559-/**\n560- * 内部消息处理函数（实际执行消息处理逻辑）\n561- */\n562-export async function handleDingTalkMessageInternal(params: HandleMessageParams): Promise<void> {\n563-  const { accountId, config, data, sessionWebhook, runtime, cfg } = params;\n564-\n565-  const log = createLoggerFromConfig(config, `DingTalk:${accountId}`);\n566-\n567-  const content = extractMessageContent(data);\n568:  if (!content.text && content.imageUrls.length === 0 && content.downloadCodes.length === 0) return;\n569-\n570-  const isDirect = data.conversationType === '1';\n571-  const senderId = data.senderStaffId || data.senderId;\n572-  const senderName = data.senderNick || 'Unknown';\n573-\n574-\n575-\n576-\n577-\n578-  // ===== DM Policy 检查 =====\n--\n768-          imageLocalPaths.push(localPath);\n769-          log?.info?.(`图片下载成功 ${i + 1}/${content.imageUrls.length}`);\n770-        } else {\n771-          log?.warn?.(`图片下载失败 ${i + 1}/${content.imageUrls.length}`);\n772-        }\n773-      } else {\n774-        const localPath = await downloadImageToFile(url, agentWorkspaceDir, log);\n775-        if (localPath) {","cwd":"/Users/liuchenglong/.openclaw/workspace"},"isError":false,"timestamp":1775016202225}}
