{"type":"message","id":"6fba0efd","parentId":"d5c3193e","timestamp":"2026-04-01T05:54:45.608Z","message":{"role":"toolResult","toolCallId":"call_bgnljp1kfh6dw1sb00rxh1kt","toolName":"exec","content":[{"type":"text","text":"// 处理文件\n        if (part.type === 'file' && part.downloadCode) {\n          downloadCodes.push(part.downloadCode);\n          fileNames.push(part.fileName || '文件');\n        }\n      }\n\n      const text = textParts.join('') || (imageUrls.length > 0 ? '[图片]' : (downloadCodes.length > 0 ? '[媒体文件]' : '[富文本消息]'));\n      return { text, messageType: 'richText', imageUrls, downloadCodes, fileNames, atDingtalkIds: [], atMobiles: [] };\n    }\n    case 'picture': {\n      const downloadCode = data.content?.downloadCode || '';\n      const pictureUrl = data.content?.pictureUrl || '';\n      const imageUrls: string[] = [];\n      const downloadCodes: string[] = [];\n\n      if (pictureUrl) {\n        imageUrls.push(pictureUrl);\n      }\n      if (downloadCode) {\n        downloadCodes.push(downloadCode);\n      }\n\n      return { text: '[图片]', messageType: 'picture', imageUrls, downloadCodes, fileNames: [], atDingtalkIds: [], atMobiles: [] };\n    }\n    case 'audio': {\n      const audioDownloadCode = data.content?.downloadCode || '';\n      const audioFileName = data.content?.fileName || 'audio.amr';\n      const downloadCodes: string[] = [];\n      const fileNames: string[] = [];\n      if (audioDownloadCode) {\n        downloadCodes.push(audioDownloadCode);\n        fileNames.push(audioFileName);\n      }\n      return { \n        text: data.content?.recognition || '[语音消息]', \n        messageType: 'audio', \n        imageUrls: [], \n        downloadCodes, \n        fileNames, \n        atDingtalkIds: [],"}],"details":{"status":"completed","exitCode":0,"durationMs":15,"aggregated":"// 处理文件\n        if (part.type === 'file' && part.downloadCode) {\n          downloadCodes.push(part.downloadCode);\n          fileNames.push(part.fileName || '文件');\n        }\n      }\n\n      const text = textParts.join('') || (imageUrls.length > 0 ? '[图片]' : (downloadCodes.length > 0 ? '[媒体文件]' : '[富文本消息]'));\n      return { text, messageType: 'richText', imageUrls, downloadCodes, fileNames, atDingtalkIds: [], atMobiles: [] };\n    }\n    case 'picture': {\n      const downloadCode = data.content?.downloadCode || '';\n      const pictureUrl = data.content?.pictureUrl || '';\n      const imageUrls: string[] = [];\n      const downloadCodes: string[] = [];\n\n      if (pictureUrl) {\n        imageUrls.push(pictureUrl);\n      }\n      if (downloadCode) {\n        downloadCodes.push(downloadCode);\n      }\n\n      return { text: '[图片]', messageType: 'picture', imageUrls, downloadCodes, fileNames: [], atDingtalkIds: [], atMobiles: [] };\n    }\n    case 'audio': {\n      const audioDownloadCode = data.content?.downloadCode || '';\n      const audioFileName = data.content?.fileName || 'audio.amr';\n      const downloadCodes: string[] = [];\n      const fileNames: string[] = [];\n      if (audioDownloadCode) {\n        downloadCodes.push(audioDownloadCode);\n        fileNames.push(audioFileName);\n      }\n      return { \n        text: data.content?.recognition || '[语音消息]', \n        messageType: 'audio', \n        imageUrls: [], \n        downloadCodes, \n        fileNames, \n        atDingtalkIds: [],","cwd":"/Users/liuchenglong/.openclaw/workspace"},"isError":false,"timestamp":1775022885605}}
{"type":"message","id":"a74652cb","parentId":"6fba0efd","timestamp":"2026-04-01T05:54:54.257Z","message":{"role":"assistant","content":[{"type":"text","text":"现在看来逻辑是对的。`audioDownloadCode` 从 `data.content.downloadCode` 读取，有值才会加到 `downloadCodes` 数组，否则就不下载。那问题就是 —— 实际钉钉返回的数据里，`downloadCode` 不在 `data.content`，它在别的地方？\n\n现在我们加上调试日志，把收到的完整语音消息结构打出来，这样就能看到下载码到底在哪里：\n\n\n\n"},{"type":"toolCall","id":"call_ass6olpe4jn04md394qpooqt","name":"edit","arguments":{"path":"/Users/liuchenglong/.openclaw/extensions/dingtalk-connector/src/core/message-handler.ts","oldText":"    case 'audio': {\n      const audioDownloadCode = data.content?.downloadCode || '';\n      const audioFileName = data.content?.fileName || 'audio.amr';\n      const downloadCodes: string[] = [];\n      const fileNames: string[] = [];\n      if (audioDownloadCode) {\n        downloadCodes.push(audioDownloadCode);\n        fileNames.push(audioFileName);\n      }\n      return { \n        text: data.content?.recognition || '[语音消息]', \n        messageType: 'audio', \n        imageUrls: [], \n        downloadCodes, \n        fileNames, \n        atDingtalkIds: [],","newText":"    case 'audio': {\n      const audioDownloadCode = data.content?.downloadCode || '';\n      const audioFileName = data.content?.fileName || 'audio.amr';\n      log?.info?.(`Received audio message, full data: ${JSON.stringify(data, null, 2)}`);\n      const downloadCodes: string[] = [];\n      const fileNames: string[] = [];\n      if (audioDownloadCode) {\n        downloadCodes.push(audioDownloadCode);\n        fileNames.push(audioFileName);\n        log?.info?.(`Found audio downloadCode: ${audioDownloadCode}, fileName: ${audioFileName}`);\n      } else {\n        log?.warn?.(`No downloadCode found in audio message, will not download file! Checked path: data.content.downloadCode = ${audioDownloadCode}`);\n      }\n      return { \n        text: data.content?.recognition || '[语音消息]', \n        messageType: 'audio', \n        imageUrls: [], \n        downloadCodes, \n        fileNames, \n        atDingtalkIds: [],"}}],"api":"anthropic-messages","provider":"custom-ark-cn-beijing-volces-com","model":"ark-code-latest","usage":{"input":4482,"output":554,"cacheRead":25400,"cacheWrite":0,"totalTokens":30436,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775022885610,"responseId":"021775022885738660859622656fea2a03bf0be4d40d0802aa208"}}
