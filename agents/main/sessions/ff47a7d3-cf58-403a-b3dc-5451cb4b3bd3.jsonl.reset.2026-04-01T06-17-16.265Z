30 22:04 index.ts\n-rwxr-xr-x@   1 liuchenglong  staff   16938 Mar 30 22:04 install-beta.sh\n-rwxr-xr-x@   1 liuchenglong  staff    5891 Mar 30 22:04 install-npm.sh\ndrwxr-xr-x@ 361 liuchenglong  staff   11552 Mar 30 22:05 node_modules\n-rw-r--r--@   1 liuchenglong  staff     468 Mar 30 22:04 openclaw.plugin.json\n-rw-r--r--@   1 liuchenglong  staff  360010 Mar 30 22:05 package-lock.json\n-rw-r--r--@   1 liuchenglong  staff    2506 Mar 30 22:04 package.json\ndrwxr-xr-x@   3 liuchenglong  staff      96 Mar 30 22:04 skills\ndrwxr-xr-x@  19 liuchenglong  staff     608 Mar 30 22:04 src\n-rw-r--r--@   1 liuchenglong  staff     495 Mar 30 22:04 tsconfig.json","cwd":"/Users/liuchenglong/.openclaw/workspace"},"isError":false,"timestamp":1775016047316}}
