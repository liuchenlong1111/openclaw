art.downloadCode);\n193-          fileNames.push(part.fileName || '文件');\n194-        }\n195-      }\n196-\n197-      const text = textParts.join('') || (imageUrls.length > 0 ? '[图片]' : (downloadCodes.length > 0 ? '[媒体文件]' : '[富文本消息]'));\n198-      return { text, messageType: 'richText', imageUrls, downloadCodes, fileNames, atDingtalkIds: [], atMobiles: [] };\n199-    }\n200-    case 'picture': {\n201-      const downloadCode = data.content?.downloadCode || '';\n202-      const pictureUrl = data.content?.pictureUrl || '';\n203-      const imageUrls: string[] = [];\n204-      const downloadCodes: string[] = [];\n205-\n206-      if (pictureUrl) {\n207-        imageUrls.push(pictureUrl);\n208-      }\n209-      if (downloadCode) {\n210-        downloadCodes.push(downloadCode);\n211-      }\n212-\n213-      return { text: '[图片]', messageType: 'picture', imageUrls, downloadCodes, fileNames: [], atDingtalkIds: [], atMobiles: [] };\n214-    }\n215-    case 'audio': {\n216-      const audioDownloadCode = data.content?.downloadCode || '';\n217-      const audioFileName = data.content?.fileName || 'audio.amr';\n218-      const downloadCodes: string[] = [];\n219-      const fileNames: string[] = [];\n220-      if (audioDownloadCode) {\n221-        downloadCodes.push(audioDownloadCode);\n222-        fileNames.push(audioFileName);\n223-      }\n224-      return { \n225-        text: data.content?.recognition || '[语音消息]', \n226-        messageType: 'audio',"}],"details":{"status":"completed","exitCode":0,"durationMs":15,"aggregated":"146:export function extractMessageContent(data: any): ExtractedMessage {\n147-  const msgtype = data.msgtype || 'text';\n148-  switch (msgtype) {\n149-    case 'text': {\n150-      const atDingtalkIds = data.text?.at?.atDingtalkIds || [];\n151-      const atMobiles = data.text?.at?.atMobiles || [];\n152-      return { \n153-        text: data.text?.content?.trim() || '', \n154-        messageType: 'text', \n155-        imageUrls: [], \n156-        downloadCodes: [], \n157-        fileNames: [],\n158-        atDingtalkIds,\n159-        atMobiles\n160-      };\n161-    }\n162-    case 'richText': {\n163-      const parts = data.content?.richText || [];\n164-      const textParts: string[] = [];\n165-      const imageUrls: string[] = [];\n166-      const downloadCodes: string[] = [];\n167-      const fileNames: string[] = [];\n168-\n169-      for (const part of parts) {\n170-        if (part.text) {\n171-          textParts.push(part.text);\n172-        }\n173-        // 处理图片\n174-        if (part.pictureUrl) {\n175-          imageUrls.push(part.pictureUrl);\n176-        }\n177-        if (part.type === 'picture' && part.downloadCode) {\n178-          imageUrls.push(`downloadCode:${part.downloadCode}`);\n179-        }\n180-        // 处理视频\n181-        if (part.type === 'video' && part.downloadCode) {\n182-          downloadCodes.push(part.downloadCode);\n183-          fileNames.push(part.fileName || 'video.mp4');\n184-        }\n185-        // 处理音频\n186-        if (part.type === 'audio' && part.downloadCode) {\n187-          downloadCodes.push(part.downloadCode);\n188-          fileNames.push(part.fileName || 'audio');\n189-        }\n190-        // 处理文件\n191-        if (part.type === 'file' && part.downloadCode) {\n192-          downloadCodes.push(part.downloadCode);\n193-          fileNames.push(part.fileName || '文件');\n194-        }\n195-      }\n196-\n197-      const text = textParts.join('') || (imageUrls.length > 0 ? '[图片]' : (downloadCodes.length > 0 ? '[媒体文件]' : '[富文本消息]'));\n198-      return { text, messageType: 'richText', imageUrls, downloadCodes, fileNames, atDingtalkIds: [], atMobiles: [] };\n199-    }\n200-    case 'picture': {\n201-      const downloadCode = data.content?.downloadCode || '';\n202-      const pictureUrl = data.content?.pictureUrl || '';\n203-      const imageUrls: string[] = [];\n204-      const downloadCodes: string[] = [];\n205-\n206-      if (pictureUrl) {\n207-        imageUrls.push(pictureUrl);\n208-      }\n209-      if (downloadCode) {\n210-        downloadCodes.push(downloadCode);\n211-      }\n212-\n213-      return { text: '[图片]', messageType: 'picture', imageUrls, downloadCodes, fileNames: [], atDingtalkIds: [], atMobiles: [] };\n214-    }\n215-    case 'audio': {\n216-      const audioDownloadCode = data.content?.downloadCode || '';\n217-      const audioFileName = data.content?.fileName || 'audio.amr';\n218-      const downloadCodes: string[] = [];\n219-      const fileNames: string[] = [];\n220-      if (audioDownloadCode) {\n221-        downloadCodes.push(audioDownloadCode);\n222-        fileNames.push(audioFileName);\n223-      }\n224-      return { \n225-        text: data.content?.recognition || '[语音消息]', \n226-        messageType: 'audio',","cwd":"/Users/liuchenglong/.openclaw/workspace"},"isError":false,"timestamp":1775016207213}}
{"type":"message","id":"bd3bb709","parentId":"775df410","timestamp":"2026-04-01T04:03:30.556Z","message":{"role":"assistant","content":[{"type":"text","text":"完美！找到问题了！钉钉发送语音消息时，`msgtype` 就是 `audio`，而且在 `extractMessageContent` 函数里已经正确处理了，会把 `recognition`（钉钉自动识别的文字）放到 `text` 里，下载码也放到了 `downloadCodes` 里，文件名也有了，是 `audio.amr` 不是 mp3！\n\n我之前一直搜mp3当然搜不到！让我看看：\n\n\n\n\n"},{"type":"toolCall","id":"call_fz8lf5zkml02zgo0thegftcr","name":"exec","arguments":{"command":"ls -la /Users/liuchenglong/.openclaw/workspace/media/inbound/*.amr 2>/dev/null"}}],"api":"anthropic-messages","provider":"custom-ark-cn-beijing-volces-com","model":"ark-code-latest","usage":{"input":3477,"output":158,"cacheRead":24888,"cacheWrite":0,"totalTokens":28523,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775016207218,"responseId":"0217750162072881cf45d11d421f4f872a8e52de4f86b4fb9e543"}}
