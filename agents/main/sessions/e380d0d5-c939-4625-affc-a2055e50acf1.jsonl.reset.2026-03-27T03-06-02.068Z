{"type":"message","id":"b7bfd932","parentId":"e2463a82","timestamp":"2026-03-27T02:51:02.088Z","message":{"role":"toolResult","toolCallId":"call_ckyn8r0srct2enlskku3aoef","toolName":"exec","content":[{"type":"text","text":"3365:const dingtalkPlugin = {\n3366-  id: 'dingtalk-connector',\n3367-  meta,\n3368-  capabilities: {\n3369-    chatTypes: ['direct', 'group'],\n3370-    reactions: false,\n3371-    threads: false,\n3372-    media: true,\n3373-    nativeCommands: false,\n3374-    blockStreaming: false,\n3375-  },\n3376-  reload: { configPrefixes: ['channels.dingtalk-connector'] },\n3377-  configSchema: {\n3378-    schema: {\n3379-      type: 'object',\n3380-      additionalProperties: false,\n3381-      properties: {\n3382-        enabled: { type: 'boolean', default: true },\n3383-        clientId: { type: 'string', description: 'DingTalk App Key (Client ID)' },\n3384-        clientSecret: { type: 'string', description: 'DingTalk App Secret (Client Secret)' },\n3385-        enableMediaUpload: { type: 'boolean', default: true, description: 'Enable media upload prompt injection' },\n3386-        systemPrompt: { type: 'string', default: '', description: 'Custom system prompt' },\n3387-        dmPolicy: { type: 'string', enum: ['open', 'pairing', 'allowlist'], default: 'open' },\n3388-        allowFrom: { type: 'array', items: { type: 'string' }, description: 'Allowed sender IDs' },\n3389-        groupPolicy: { type: 'string', enum: ['open', 'allowlist'], default: 'open' },\n3390-        gatewayToken: { type: 'string', default: '', description: 'Gateway auth token (Bearer)' },\n3391-        gatewayPassword: { type: 'string', default: '', description: 'Gateway auth password (alternative to token)' },\n3392-        gatewayBaseUrl: { type: 'string', default: '', description: 'Custom Gateway URL (e.g., http://127.0.0.1:18788 for Nginx proxy to TLS Gateway)' },\n3393-        sessionTimeout: { type: 'number', default: 1800000, description: 'Session timeout in ms (default 30