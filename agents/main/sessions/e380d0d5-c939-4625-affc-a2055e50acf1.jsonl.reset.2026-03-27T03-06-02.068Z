ctive,\n4122-  sendVideoProactive,\n4123-  sendAICardInternal,\n4124-  sendAICardToUser,\n4125-  sendAICardToGroup,\n4126-  // 主动消息\n4127-  sendNormalToUser,\n4128-  sendNormalToGroup,\n4129-  sendToUser,\n4130-  sendToGroup,\n4131-  sendProactive,"}],"details":{"status":"completed","exitCode":0,"durationMs":16,"aggregated":"4051:export default plugin;\n4052-export {\n4053-  dingtalkPlugin,\n4054-  // 回复消息（需要 sessionWebhook）\n4055-  sendMessage,\n4056-  sendTextMessage,\n4057-  sendMarkdownMessage,\n4058-  // 主动发送消息（无需 sessionWebhook）\n4059-  sendToUser,\n4060-  sendToGroup,\n4061-  sendProactive,\n4062-  // 钉钉文档客户端\n4063-  DingtalkDocsClient,\n4064-};\n4065-\n4066-// ============ 测试辅助导出 ============\n4067-// 仅用于单元测试，避免在业务代码中直接依赖内部实现细节\n4068-export const __testables = {\n4069-  // Markdown 修正\n4070-  ensureTableBlankLines,\n4071-  // 会话 & 去重\n4072-  normalizeSlashCommand,\n4073-  buildSessionContext,\n4074-  isMessageProcessed,\n4075-  markMessageProcessed,\n4076-  cleanupProcessedMessages,\n4077-  // 配置 & Token\n4078-  getConfig,\n4079-  isConfigured,\n4080-  getAccessToken,\n4081-  getOapiAccessToken,\n4082-  getUnionId,\n4083-  // 媒体处理\n4084-  toLocalPath,\n4085-  processLocalImages,\n4086-  uploadMediaToDingTalk,\n4087-  downloadImageToFile,\n4088-  downloadMediaByCode,\n4089-  downloadFileByCode,\n4090-  // 视频处理\n4091-  extractVideoMetadata,\n4092-  extractVideoThumbnail,\n4093-  processVideoMarkers,\n4094-  sendVideoMessage,\n4095-  // 音频处理\n4096-  getFfprobePath,\n4097-  extractAudioDuration,\n4098-  sendAudioMessage,\n4099-  processAudioMarkers,\n4100-  isAudioFile,\n4101-  // 文件处理\n4102-  extractFileMarkers,\n4103-  sendFileMessage,\n4104-  processFileMarkers,\n4105-  // 消息内容提取\n4106-  extractMessageContent,\n4107-  // 消息发送\n4108-  sendMarkdownMessage,\n4109-  sendTextMessage,\n4110-  sendMessage,\n4111-  // 提示词与消息体\n4112-  buildMediaSystemPrompt,\n4113-  buildDeliverBody,\n4114-  buildMsgPayload,\n4115-  // AI Card\n4116-  createAICard,\n4117-  streamAICar