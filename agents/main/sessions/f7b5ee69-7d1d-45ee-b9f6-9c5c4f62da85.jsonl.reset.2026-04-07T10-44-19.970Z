Name\":\"subsystem-CJEvHE2o.js\",\"fileNameWithLine\":\"subsystem-CJEvHE2o.js:453\",\"fileColumn\":\"51\",\"fileLine\":\"453\",\"filePath\":\"Users/liuchenglong/.nvm/versions/node/v23.11.1/lib/node_modules/openclaw/dist/subsystem-CJEvHE2o.js\",\"filePathWithLine\":\"Users/liuchenglong/.nvm/versions/node/v23.11.1/lib/node_modules/openclaw/dist/subsystem-CJEvHE2o.js:453\",\"method\":\"logToFile\"}},\"time\":\"2026-04-07T18:32:37.150+08:00\"}\n555:{\"0\":\"问题很清楚了，**错误还是一样的**：\\n\\n```\\nThe number of tokens to keep from the initial prompt is greater than the context length \\n(n_keep: 18320 >= n_ctx: 4096)\\n```\\n\\n虽然你改了 OpenClaw 配置里的 `contextWindow`，但 **llama.cpp 服务端加载模型时仍然只分配了 4096 的上下文**，问题根本没有解决。\\n\\n你是怎么启动 llama.cpp server 的？把你的启动命令或者脚本给我看一下。要在**启动服务的时候**加上 `--ctx-size 131072` 或者更大的参数才行。\\n\\n---\\n\\n顺便说一下，`n_keep` 已经到 18k+ 了，即使开 128k（131072）也完全足够。\",\"_meta\":{\"runtime\":\"node\",\"runtimeVersion\":\"25.9.0\",\"hostname\":\"unknown\",\"name\":\"openclaw\",\"date\":\"2026-04-07T10:33:15.382Z\",\"logLevelId\":3,\"logLevelName\":\"INFO\",\"path\":{\"fullFilePath\":\"file:///Users/liuchenglong/.nvm/versions/node/v23.11.1/lib/node_modules/openclaw/dist/subsystem-CJEvHE2o.js:279:46\",\"fileName\":\"subsystem-CJEvHE2o.js\",\"fileNameWithLine\":\"subsystem-CJEvHE2o.js:279\",\"fileColumn\":\"46\",\"fileLine\":\"279\",\"filePath\":\"Users/liuchenglong/.nvm/versions/node/v23.11.1/lib/node_modules/openclaw/dist/subsystem-CJEvHE2o.js\",\"filePathWithLine\":\"Users/liuchenglong/.nvm/versions/node/v23.11.1/lib/node_modules/openclaw/dist/subsystem-CJEvHE2o.js:279\"}},\"time\":\"2026-04-07T18:33:15.382+08:00\"}"}],"details":{"status":"completed","exitCode":0,"durationMs":41,"aggregated":"302:{\"0\":\"{\\\"subsystem\\\":\\\"agent/embedded\\\"}\",\"1\":{\"event\":\"embedded_run_agent_end\",\"tags\":[\"error_handling\",\"lifecycle\",\"agent_end\",\"assistant_error\"],\"runId\":\"3e1afb8b-4a63-4332-9613-458484d26070\",\"isError\":true,\"error\":\"The number of tokens to keep fro