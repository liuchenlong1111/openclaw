{"type":"message","id":"a301882d","parentId":"f5ac9f2f","timestamp":"2026-03-22T20:13:32.769Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_l9zc71c0yaisoo0dsgajbrf0","name":"web_fetch","arguments":{"url":"https://discord.com/invite/clawd","extractMode":"markdown","maxChars":2000}}],"api":"anthropic-messages","provider":"custom-ark-cn-beijing-volces-com","model":"ark-code-latest","usage":{"input":22075,"output":73,"cacheRead":0,"cacheWrite":0,"totalTokens":22148,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774210410911}}
