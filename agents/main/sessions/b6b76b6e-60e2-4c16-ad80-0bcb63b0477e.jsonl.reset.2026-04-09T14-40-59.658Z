 not set\", file=sys.stderr)\n        sys.exit(1)\n    \n    # For Volces Ark platform, endpoint is: /api/v3/inference/{endpoint_id}\n    if ENDPOINT_ID:\n        url = f\"{BASE_URL}/inference/{ENDPOINT_ID}\"\n    else:\n        url = f\"{BASE_URL}/contents/generations/tasks\"\n    \n    headers = {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": f\"Bearer {API_KEY}\",\n    }"}]}}],"api":"anthropic-messages","provider":"custom-ark-cn-beijing-volces-com","model":"ark-code-latest","usage":{"input":2664,"output":746,"cacheRead":31032,"cacheWrite":0,"totalTokens":34442,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775666400206,"responseId":"021775666400247e8eb33bba790666117f5ace3387e1842e5c75f"}}
