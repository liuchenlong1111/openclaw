{"type":"message","id":"d8ca17bc","parentId":"874ea25f","timestamp":"2026-03-21T14:33:34.376Z","message":{"role":"toolResult","toolCallId":"call_sd0cahz840gj276uqztj2jrj","toolName":"exec","content":[{"type":"text","text":"Creating video task: model=doubao-seedance-1.5, mode=text_to_video\nERROR: API call failed: Client error '404 Not Found' for url 'https://ark.cn-beijing.volces.com/api/v3/video/generations'\nFor more information check: https://developer.mozilla.org/en-US/docs/Web/HTTP/Status/404\nResponse:\n\n(Command exited with code 1)"}],"details":{"status":"completed","exitCode":1,"durationMs":421,"aggregated":"Creating video task: model=doubao-seedance-1.5, mode=text_to_video\nERROR: API call failed: Client error '404 Not Found' for url 'https://ark.cn-beijing.volces.com/api/v3/video/generations'\nFor more information check: https://developer.mozilla.org/en-US/docs/Web/HTTP/Status/404\nResponse:\n\n(Command exited with code 1)","cwd":"/Users/liuchenglong/.openclaw/workspace"},"isError":false,"timestamp":1774103614374}}
{"type":"message","id":"bd97351f","parentId":"d8ca17bc","timestamp":"2026-03-21T14:33:38.524Z","message":{"role":"assistant","content":[{"type":"text","text":"看起来API端点不对，你给的示例是用的 `/api/v3/responses` 端点，而脚本用的是 `/api/v3/video/generations`。让我检查一下脚本，然后根据你的API格式调整：\n"},{"type":"toolCall","id":"call_csn3fx4dlh87mr9frpv48hkp","name":"read","arguments":{"path":"/Users/liuchenglong/.openclaw/workspace/skills/video-gen-new/scripts/generate_video.py"}}],"api":"anthropic-messages","provider":"custom-ark-cn-beijing-volces-com","model":"ark-code-latest","usage":{"input":22561,"output":104,"cacheRead":0,"cacheWrite":0,"totalTokens":22665,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774103614376}}
{"type":"message","id":"c44dccba","parentId":"bd97351f","timestamp":"2026-03-21T14:33:38.536Z","message":{"role":"toolResult","toolCallId":"call_csn3fx4dlh87mr9frpv48hkp","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n\"\"\"\nVideo Generation Script using Doubao Seedance API\nSupports: text-to-video, image-to-video, audio-video modes\n\"\"\"\nimport os\nimport sys\nimport json\nimport time\nimport base64\nimport httpx\nfrom pathlib import Path\n\nAPI_KEY = os.environ.get(\"VIDEO_GEN_API_KEY\", \"\")\nBASE_URL = os.environ.get(\"VIDEO_GEN_BASE_URL\", \"https://ark.cn-beijing.volces.com/api/v3\")\n\ndef create_video_task(\n    prompt: str,\n    model: str = \"doubao-seedance-1.5\",\n    mode: str = \"text_to_video\",\n    first_frame: str = None,  # base64 or URL\n    last_frame: str = None,   # base64 or URL\n    reference_image: str = None,  # for seedance-lite\n    audio_enabled: bool = False,\n    aspect_ratio: str = \"16:9\",\n    duration: int = 5,\n) -> dict:\n    \"\"\"Create video generation task\"\"\"\n    \n    if not API_KEY:\n        print(\"ERROR: VIDEO_GEN_API_KEY not set\", file=sys.stderr)\n        sys.exit(1)\n    \n    url = f\"{BASE_URL}/video/generations\"\n    \n    headers = {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": f\"Bearer {API_KEY}\",\n    }\n    \n    payload = {\n        \"model\": model,\n        \"prompt\": prompt,\n        \"aspect_ratio\": aspect_ratio,\n        \"duration\": duration,\n    }\n    \n    # Handle different modes\n    if mode == \"image_to_video\" and first_frame:\n        payload[\"first_frame\"] = first_frame\n    elif mode == \"image_to_video_base64\" and first_frame:\n        # Assume first_frame is file path, encode to base64\n        if os.path.exists(first_frame):\n            with open(first_frame, \"rb\") as f:\n                payload[\"first_frame\"] = base64.b64encode(f.read()).decode()\n        else:\n            payload[\"first_frame\"] = first_frame  # already base64\n    elif mode == \"audio_video_first_frame\" and first_frame:\n        payload[\"first_frame\"] = first_frame\n        payload[\"audio_enabled\"] = True\n    elif mode == \"audio_video_first_last_frame\" and first_frame and last_frame:\n        payload[\"first_frame\"] = first_frame\n        payload[\"last_frame\"] = last_frame\n        payload[\"audio_enabled\"] = True\n    elif mode == \"seedance_lite_reference\" and reference_image:\n        payload[\"reference_image\"] = reference_image\n        payload[\"model\"] = \"seedance-lite\"\n    \n    print(f\"Creating video task: model={model}, mode={mode}\", file=sys.stderr)\n    \n    try:\n        with httpx.Client(timeout=60.0) as client:\n            response = client.post(url, headers=headers, json=payload)\n            response.raise_for_status()\n            result = response.json()\n    except Exception as e:\n        print(f\"ERROR: API call failed: {e}\", file=sys.stderr)\n        if hasattr(e, 'response') and e.response is not None:\n            print(f\"Response: {e.response.text}\", file=sys.stderr)\n        sys.exit(1)\n    \n    return result\n\n\ndef query_video_task(task_id: str) -> dict:\n    \"\"\"Query video generation task status\"\"\"\n    \n    url = f\"{BASE_URL}/video/generations/{task_id}\"\n    \n    headers = {\n        \"Authorization\": f\"Bearer {API_KEY}\",\n    }\n    \n    try:\n        with httpx.Client(timeout=30.0) as client:\n            response = client.get(url, headers=headers)\n            response.raise_for_status()\n            return response.json()\n    except Exception as e:\n        print(f\"ERROR: Query failed: {e}\", file=sys.stderr)\n        sys.exit(1)\n\n\ndef wait_for_completion(task_id: str, timeout: int = 600, poll_interval: int = 10) -> dict:\n    \"\"\"Wait for video generation to complete\"\"\"\n    \n    start_time = time.time()\n    \n    while time.time() - start_time < timeout:\n        result = query_video_task(task_id)\n        status = result.get(\"status\", \"unknown\")\n        \n        print(f\"Task {task_id}: status={status}\", file=sys.stderr)\n        \n        if status == \"completed\":\n            return result\n        elif status == \"failed\":\n            print(f\"ERROR: Task failed: {result}\", file=sys.stderr)\n            sys.exit(1)\n        \n        time.sleep(poll_interval)\n    \n    print(f\"ERROR: Timeout waiting for task {task_id}\", file=sys.stderr)\n    sys.exit(1)\n\n\ndef download_video(video_url: str, output_path: str) -> str:\n    \"\"\"Download generated video\"\"\"\n    \n    try:\n        with httpx.Client(timeout=120.0) as client:\n            response = client.get(video_url)\n            response.raise_for_status()\n            \n            with open(output_path, \"wb\") as f:\n                f.write(response.content)\n            \n            print(f\"Video downloaded to: {output_path}\", file=sys.stderr)\n            return output_path\n    except Exception as e:\n        print(f\"ERROR: Download failed: {e}\", file=sys.stderr)\n        sys.exit(1)\n\n\ndef generate_video(\n    prompt: str,\n    mode: str = \"text_to_video\",\n    model: str = \"doubao-seedance-1.5\",\n    first_frame: str = None,\n    last_frame: str = None,\n    reference_image: str = None,\n    audio_enabled: bool = False,\n    output: str = None,\n    wait: bool = True,\n) -> str:\n    \"\"\"Main video generation function\"\"\"\n    \n    # Create task\n    task = create_video_task(\n        prompt=prompt,\n        model=model,\n        mode=mode,\n        first_frame=first_frame,\n        last_frame=last_frame,\n        reference_image=reference_image,\n        audio_enabled=audio_enabled,\n    )\n    \n    task_id = task.get(\"id\") or task.get(\"task_id\")\n    print(f\"Task created: {task_id}\", file=sys.stderr)\n    \n    if not wait:\n        return json.dumps({\"task_id\": task_id, \"status\": \"pending\"})\n    \n    # Wait for completion\n    result = wait_for_completion(task_id)\n    \n    # Get video URL\n    video_url = result.get(\"video_url\") or result.get(\"output\", {}).get(\"video_url\")\n    \n    if not video_url:\n        print(f\"ERROR: No video URL in result: {result}\", file=sys.stderr)\n        sys.exit(1)\n    \n    # Download video\n    if output:\n        output_path = output\n    else:\n        output_path = str(Path.cwd() / f\"video_{task_id}.mp4\")\n    \n    download_video(video_url, output_path)\n    \n    return output_path\n\n\nif __name__ == \"__main__\":\n    import argparse\n    parser = argparse.ArgumentParser(description=\"Generate video with Doubao Seedance\")\n    parser.add_argument(\"prompt\", help=\"Text prompt for video generation\")\n    parser.add_argument(\"--mode\", \"-m\", default=\"text_to_video\", \n                        choices=[\"text_to_video\", \"image_to_video\", \"image_to_video_base64\",\n                                 \"audio_video_first_frame\", \"audio_video_first_last_frame\",\n                                 \"seedance_lite_reference\"],\n                        help=\"Generation mode\")\n    parser.add_argument(\"--model\", default=\"doubao-seedance-1.5\", help=\"Model name\")\n    parser.add_argument(\"--first-frame\", help=\"First frame image (URL or base64 or file path)\")\n    parser.add_argument(\"--last-frame\", help=\"Last frame image (URL or base64 or file path)\")\n    parser.add_argument(\"--reference-image\", help=\"Reference image for seedance-lite\")\n    parser.add_argument(\"--audio\", action=\"store_true\", help=\"Enable audio\")\n    parser.add_argument(\"--output\", \"-o\", help=\"Output video file path\")\n    parser.add_argument(\"--no-wait\", action=\"store_true\", help=\"Don't wait for completion\")\n    args = parser.parse_args()\n    \n    result = generate_video(\n        prompt=args.prompt,\n        mode=args.mode,\n        model=args.model,\n        first_frame=args.first_frame,\n        last_frame=args.last_frame,\n        reference_image=args.reference_image,\n        audio_enabled=args.audio,\n        output=args.output,\n        wait=not args.no_wait,\n    )\n    \n    print(result)\n"}],"isError":false,"timestamp":1774103618533}}
{"type":"message","id":"ac0a2b79","parentId":"c44dccba","timestamp":"2026-03-21T14:33:54.756Z","message":{"role":"assistant","content":[{"type":"text","text":"我看到问题了。你使用的模型是 `doubao-seed-1-8-251228`，API 端点应该是 `/api/v3/responses` 而不是 `/api/v3/video/generations`。这是不同的 API 调用格式。让我根据你提供的示例修改脚本：\n\n"},{"type":"toolCall","id":"call_ezf2nurxp9azrdmh4iynwtnp","name":"edit","arguments":{"path":"/Users/liuchenglong/.openclaw/workspace/skills/video-gen-new/scripts/generate_video.py","old_string":"#!/usr/bin/env python3\n\"\"\"\nVideo Generation Script using Doubao Seedance API\nSupports: text-to-video, image-to-video, audio-video modes\n\"\"\"\nimport os\nimport sys\nimport json\nimport time\nimport base64\nimport httpx\nfrom pathlib import Path\n\nAPI_KEY = os.environ.get(\"VIDEO_GEN_API_KEY\", \"\")\nBASE_URL = os.environ.get(\"VIDEO_GEN_BASE_URL\", \"https://ark.cn-beijing.volces.com/api/v3\")\n\ndef create_video_task(\n    prompt: str,\n    model: str = \"doubao-seedance-1.5\",\n    mode: str = \"text_to_video\",\n    first_frame: str = None,  # base64 or URL\n    last_frame: str = None,   # base64 or URL\n    reference_image: str = None,  # for seedance-lite\n    audio_enabled: bool = False,\n    aspect_ratio: str = \"16:9\",\n    duration: int = 5,\n) -> dict:\n    \n    if not API_KEY:\n        print(\"ERROR: VIDEO_GEN_API_KEY not set\", file=sys.stderr)\n        sys.exit(1)\n    \n    url = f\"{BASE_URL}/video/generations\"\n    \n    headers = {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": f\"Bearer {API_KEY}\",\n    }\n    \n    payload = {\n        \"model\": model,\n        \"prompt\": prompt,\n        \"aspect_ratio\": aspect_ratio,\n        \"duration\": duration,\n    }\n    \n    # Handle different modes\n    if mode == \"image_to_video\" and first_frame:\n        payload[\"first_frame\"] = first_frame\n    elif mode == \"image_to_video_base64\" and first_frame:\n        # Assume first_frame is file path, encode to base64\n        if os.path.exists(first_frame):\n            with open(first_frame, \"rb\") as f:\n                payload[\"first_frame\"] = base64.b64encode(f.read()).decode()\n        else:\n            payload[\"first_frame\"] = first_frame  # already base64\n    elif mode == \"audio_video_first_frame\" and first_frame:\n        payload[\"first_frame\"] = first_frame\n        payload[\"audio_enabled\"] = True\n    elif mode == \"audio_video_first_last_frame\" and first_frame and last_frame:\n        payload[\"first_frame\"] = first_frame\n        payload[\"last_frame\"] = last_frame\n        payload[\"audio_enabled\"] = True\n    elif mode == \"seedance_lite_reference\" and reference_image:\n        payload[\"reference_image\"] = reference_image\n        payload[\"model\"] = \"seedance-lite\"\n    \n    print(f\"Creating video task: model={model}, mode={mode}\", file=sys.stderr)\n    \n    try:\n        with httpx.Client(timeout=60.0) as client:\n            response = client.post(url, headers=headers, json=payload)\n            response.raise_for_status()\n            result = response.json()\n    except Exception as e:\n        print(f\"ERROR: API call failed: {e}\", file=sys.stderr)\n        if hasattr(e, 'response') and e.response is not None:\n            print(f\"Response: {e.response.text}\", file=sys.stderr)\n        sys.exit(1)\n    \n    return result","new_string":"#!/usr/bin/env python3\n\"\"\"\nVideo Generation Script using Doubao Seedance API\nSupports: text-to-video, image-to-video, audio-video modes\nSupports both /video/generations and /responses endpoints\n\"\"\"\nimport os\nimport sys\nimport json\nimport time\nimport base64\nimport httpx\nfrom pathlib import Path\n\nAPI_KEY = os.environ.get(\"VIDEO_GEN_API_KEY\", \"\")\nBASE_URL = os.environ.get(\"VIDEO_GEN_BASE_URL\", \"https://ark.cn-beijing.volces.com/api/v3\")\n\ndef create_video_task(\n    prompt: str,\n    model: str = \"doubao-seedance-1.5\",\n    mode: str = \"text_to_video\",\n    first_frame: str = None,  # base64 or URL\n    last_frame: str = None,   # base64 or URL\n    reference_image: str = None,  # for seedance-lite\n    audio_enabled: bool = False,\n    aspect_ratio: str = \"16:9\",\n    duration: int = 5,\n) -> dict:\n    \n    if not API_KEY:\n        print(\"ERROR: VIDEO_GEN_API_KEY not set\", file=sys.stderr)\n        sys.exit(1)\n    \n    # Check if using doubao-seed model (uses /responses endpoint)\n    if \"doubao-seed\" in model:\n        # Use responses endpoint format (like user's curl example)\n        url = f\"{BASE_URL}/responses\"\n        headers = {\n            \"Content-Type\": \"application/json\",\n            \"Authorization\": f\"Bearer {API_KEY}\",\n        }\n        \n        # Build content array\n        content = []\n        \n        # For text-to-video with doubao-seed, format is different\n        content.append({\n            \"type\": \"input_text\",\n            \"text\": prompt\n        })\n        \n        # If we have first frame image\n        if first_frame and (mode == \"image_to_video\" or mode == \"image_to_video_base64\"):\n            if mode == \"image_to_video_base64\" and os.path.exists(first_frame):\n                with open(first_frame, \"rb\") as f:\n                    img_b64 = base64.b64encode(f.read()).decode()\n                    content.append({\n                        \"type\": \"input_image\",\n                        \"image_data\": img_b64\n                    })\n            elif first_frame.startswith(\"http\"):\n                content.append({\n                    \"type\": \"input_image\",\n                    \"image_url\": first_frame\n                })\n        \n        payload = {\n            \"model\": model,\n            \"input\": [\n                {\n                    \"role\": \"user\",\n                    \"content\": content\n                }\n            ]\n        }\n    else:\n        # Original /video/generations endpoint for doubao-seedance\n        url = f\"{BASE_URL}/video/generations\"\n        headers = {\n            \"Content-Type\": \"application/json\",\n            \"Authorization\": f\"Bearer {API_KEY}\",\n        }\n        payload = {\n            \"model\": model,\n            \"prompt\": prompt,\n            \"aspect_ratio\": aspect_ratio,\n            \"duration\": duration,\n        }\n        # Handle different modes\n        if mode == \"image_to_video\" and first_frame:\n            payload[\"first_frame\"] = first_frame\n        elif mode == \"image_to_video_base64\" and first_frame:\n            # Assume first_frame is file path, encode to base64\n            if os.path.exists(first_frame):\n                with open(first_frame, \"rb\") as f:\n                    payload[\"first_frame\"] = base64.b64encode(f.read()).decode()\n            else:\n                payload[\"first_frame\"] = first_frame  # already base64\n        elif mode == \"audio_video_first_frame\" and first_frame:\n            payload[\"first_frame\"] = first_frame\n            payload[\"audio_enabled\"] = True\n        elif mode == \"audio_video_first_last_frame\" and first_frame and last_frame:\n            payload[\"first_frame\"] = first_frame\n            payload[\"last_frame\"] = last_frame\n            payload[\"audio_enabled\"] = True\n        elif mode == \"seedance_lite_reference\" and reference_image:\n            payload[\"reference_image\"] = reference_image\n            payload[\"model\"] = \"seedance-lite\"\n    \n    print(f\"Creating video task: model={model}, mode={mode}, url={url}\", file=sys.stderr)\n    \n    try:\n        with httpx.Client(timeout=60.0) as client:\n            response = client.post(url, headers=headers, json=payload)\n            response.raise_for_status()\n            result = response.json()\n    except Exception as e:\n        print(f\"ERROR: API call failed: {e}\", file=sys.stderr)\n        if hasattr(e, 'response') and e.response is not None:\n            print(f\"Response: {e.response.text}\", file=sys.stderr)\n        sys.exit(1)\n    \n    return result"}}],"api":"anthropic-messages","provider":"custom-ark-cn-beijing-volces-com","model":"ark-code-latest","usage":{"input":2815,"output":1997,"cacheRead":21816,"cacheWrite":0,"totalTokens":26628,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774103618539}}
{"type":"message","id":"5e786199","parentId":"ac0a2b79","timestamp":"2026-03-21T14:33:54.776Z","message":{"role":"toolResult","toolCallId":"call_ezf2nurxp9azrdmh4iynwtnp","toolName":"edit","content":[{"type":"text","text":"{\n  \"status\": \"error\",\n  \"tool\": \"edit\",\n  \"error\": \"Could not find the exact text in /Users/liuchenglong/.openclaw/workspace/skills/video-gen-new/scripts/generate_video.py. The old text must match exactly including all whitespace and newlines.\"\n}"}],"details":{"status":"error","tool":"edit","error":"Could not find the exact text in /Users/liuchenglong/.openclaw/workspace/skills/video-gen-new/scripts/generate_video.py. The old text must match exactly including all whitespace and newlines."},"isError":false,"timestamp":1774103634773}}
{"type":"message","id":"174bbbfe","parentId":"5e786199","timestamp":"2026-03-21T14:34:06.028Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_8er86j6tlwco6b2ybyml5y3w","name":"write","arguments":{"path":"/Users/liuchenglong/.openclaw/workspace/skills/video-gen-new/scripts/generate_video_responses.py","content":"#!/usr/bin/env python3\n\"\"\"\nVideo Generation Script using Doubao Seedance API\nUses /responses endpoint with model doubao-seed-1-8-251228\n\"\"\"\nimport os\nimport sys\nimport json\nimport time\nimport base64\nimport httpx\nfrom pathlib import Path\n\nAPI_KEY = os.environ.get(\"VIDEO_GEN_API_KEY\", \"\")\nBASE_URL = os.environ.get(\"VIDEO_GEN_BASE_URL\", \"https://ark.cn-beijing.volces.com/api/v3\")\n\ndef create_video_task(\n    prompt: str,\n    model: str = \"doubao-seed-1-8-251228\",\n    first_frame: str = None,  # URL or file path\n) -> dict:\n    \"\"\"Create video generation task using responses endpoint\"\"\"\n    \n    if not API_KEY:\n        print(\"ERROR: VIDEO_GEN_API_KEY not set\", file=sys.stderr)\n        sys.exit(1)\n    \n    url = f\"{BASE_URL}/responses\"\n    \n    headers = {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": f\"Bearer {API_KEY}\",\n    }\n    \n    # Build content array\n    content = []\n    \n    # Add text prompt\n    content.append({\n        \"type\": \"input_text\",\n        \"text\": prompt\n    })\n    \n    # Add first frame if provided\n    if first_frame:\n        if os.path.exists(first_frame):\n            # Local file - encode to base64\n            with open(first_frame, \"rb\") as f:\n                img_b64 = base64.b64encode(f.read()).decode()\n                content.append({\n                    \"type\": \"input_image\",\n                    \"image_data\": img_b64\n                })\n        elif first_frame.startswith(\"http\"):\n            # URL\n            content.append({\n                \"type\": \"input_image\",\n                \"image_url\": first_frame\n            })\n    \n    payload = {\n        \"model\": model,\n        \"input\": [\n            {\n                \"role\": \"user\",\n                \"content\": content\n            }\n        ]\n    }\n    \n    print(f\"Creating video task: model={model}\", file=sys.stderr)\n    \n    try:\n        with httpx.Client(timeout=60.0) as client:\n            response = client.post(url, headers=headers, json=payload)\n            response.raise_for_status()\n            result = response.json()\n    except Exception as e:\n        print(f\"ERROR: API call failed: {e}\", file=sys.stderr)\n        if hasattr(e, 'response') and e.response is not None:\n            print(f\"Response: {e.response.text}\", file=sys.stderr)\n        sys.exit(1)\n    \n    return result\n\n\ndef extract_video_url(result: dict) -> str:\n    \"\"\"Extract video URL from response\"\"\"\n    # Try different output formats\n    if \"output\" in result:\n        output = result[\"output\"]\n        if isinstance(output, list):\n            for item in output:\n                if item.get(\"type\") == \"video\" and \"video_url\" in item:\n                    return item[\"video_url\"]\n        elif isinstance(output, dict):\n            if \"video_url\" in output:\n                return output[\"video_url\"]\n    \n    if \"video_url\" in result:\n        return result[\"video_url\"]\n    \n    # Search all fields\n    def find_video_url(obj):\n        if isinstance(obj, dict):\n            if \"video_url\" in obj:\n                return obj[\"video_url\"]\n            for v in obj.values():\n                found = find_video_url(v)\n                if found:\n                    return found\n        elif isinstance(obj, list):\n            for item in obj:\n                found = find_video_url(item)\n                if found:\n                    return found\n        return None\n    \n    return find_video_url(result)\n\n\ndef download_video(video_url: str, output_path: str) -> str:\n    \"\"\"Download generated video\"\"\"\n    \n    try:\n        with httpx.Client(timeout=120.0, follow_redirects=True) as client:\n            response = client.get(video_url)\n            response.raise_for_status()\n            \n            with open(output_path, \"wb\") as f:\n                f.write(response.content)\n            \n            print(f\"Video downloaded to: {output_path}\", file=sys.stderr)\n            return output_path\n    except Exception as e:\n        print(f\"ERROR: Download failed: {e}\", file=sys.stderr)\n        sys.exit(1)\n\n\nif __name__ == \"__main__\":\n    import argparse\n    parser = argparse.ArgumentParser(description=\"Generate video with Doubao Seed (responses endpoint)\")\n    parser.add_argument(\"prompt\", help=\"Text prompt for video generation\")\n    parser.add_argument(\"--model\", default=\"doubao-seed-1-8-251228\", help=\"Model name\")\n    parser.add_argument(\"--first-frame\", help=\"First frame image (URL or file path)\")\n    parser.add_argument(\"--output\", \"-o\", help=\"Output video file path\")\n    args = parser.parse_args()\n    \n    # Create task\n    result = create_video_task(\n        prompt=args.prompt,\n        model=args.model,\n        first_frame=args.first_frame,\n    )\n    \n    # Extract video URL\n    video_url = extract_video_url(result)\n    \n    if not video_url:\n        print(f\"ERROR: No video URL in response: {json.dumps(result, indent=2)}\", file=sys.stderr)\n        sys.exit(1)\n    \n    # Set output path\n    if args.output:\n        output_path = args.output\n    else:\n        output_path = \"generated_video.mp4\"\n    \n    # Download\n    download_video(video_url, output_path)\n    \n    print(output_path)\n"}}],"api":"anthropic-messages","provider":"custom-ark-cn-beijing-volces-com","model":"ark-code-latest","usage":{"input":26706,"output":1358,"cacheRead":0,"cacheWrite":0,"totalTokens":28064,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774103634777}}
