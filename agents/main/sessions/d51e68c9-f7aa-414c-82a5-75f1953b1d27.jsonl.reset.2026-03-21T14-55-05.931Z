{"type":"message","id":"27efc050","parentId":"6573f751","timestamp":"2026-03-21T14:36:12.500Z","message":{"role":"assistant","content":[{"type":"text","text":"找到了问题！我现在修改脚本来正确解析doubao-seed-1-8-251228返回的JSON格式：\n\n"},{"type":"toolCall","id":"call_axu8rdn1eo7b5ch6zscv0au5","name":"edit","arguments":{"path":"/Users/liuchenglong/.openclaw/workspace/skills/video-gen-new/scripts/generate_video_responses.py","old_string":"def extract_video_url(result: dict) -> str:\n    \"\"\"Extract video URL from response\"\"\"\n    # Try different output formats\n    if \"output\" in result:\n        output = result[\"output\"]\n        if isinstance(output, list):\n            for item in output:\n                if item.get(\"type\") == \"video\" and \"video_url\" in item:\n                    return item[\"video_url\"]\n        elif isinstance(output, dict):\n            if \"video_url\" in output:\n                return output[\"video_url\"]\n    \n    if \"video_url\" in result:\n        return result[\"video_url\"]\n    \n    # Search all fields\n    def find_video_url(obj):\n        if isinstance(obj, dict):\n            if \"video_url\" in obj:\n                return obj[\"video_url\"]\n            for v in obj.values():\n                found = find_video_url(v)\n                if found:\n                    return found\n        elif isinstance(obj, list):\n            for item in obj:\n                found = find_video_url(item)\n                if found:\n                    return found\n        return None\n    \n    return find_video_url(result)","new_string":"def extract_video_url(result: dict) -> str:\n    \"\"\"Extract video URL from response for doubao-seed\"\"\"\n    # Response format for doubao-seed-1-8-251228:\n    # { \"content\": [...], \"output\": [{ \"type\": \"text\", \"text\": \"...\" }] }\n    # The text contains the JSON with video_url\n    \n    # Check content field - sometimes in choices[0]\n    if \"choices\" in result and isinstance(result[\"choices\"], list):\n        for choice in result[\"choices\"]:\n            if \"message\" in choice and \"content\" in choice[\"message\"]:\n                content = choice[\"message\"][\"content\"]\n                # Content might be JSON wrapped in markdown\n                content = content.strip()\n                if content.startswith(\"```json\"):\n                    content = content[7:-3].strip()\n                elif content.startswith(\"```\"):\n                    content = content[3:-3].strip()\n                try:\n                    data = json.loads(content)\n                    if \"video_url\" in data:\n                        return data[\"video_url\"]\n                except:\n                    # Try to just extract URL directly\n                    pass\n    \n    # Check output field\n    if \"output\" in result and isinstance(result[\"output\"], list):\n        for item in result[\"output\"]:\n            if item.get(\"type\") == \"text\" and \"text\" in item:\n                text = item[\"text\"].strip()\n                if text.startswith(\"```json\"):\n                    text = text[7:-3].strip()\n                elif text.startswith(\"```\"):\n                    text = text[3:-3].strip()\n                try:\n                    data = json.loads(text)\n                    if \"video_url\" in data:\n                        return data[\"video_url\"]\n                except:\n                    continue\n    \n    # Try different output formats\n    if \"output\" in result:\n        output = result[\"output\"]\n        if isinstance(output, list):\n            for item in output:\n                if item.get(\"type\") == \"video\" and \"video_url\" in item:\n                    return item[\"video_url\"]\n        elif isinstance(output, dict):\n            if \"video_url\" in output:\n                return output[\"video_url\"]\n    \n    if \"video_url\" in result:\n        return result[\"video_url\"]\n    \n    # Search all fields\n    def find_video_url(obj):\n        if isinstance(obj, dict):\n            if \"video_url\" in obj:\n                return obj[\"video_url\"]\n            for v in obj.values():\n                found = find_video_url(v)\n                if found:\n                    return found\n        elif isinstance(obj, list):\n            for item in obj:\n                found = find_video_url(item)\n                if found:\n                    return found\n        return None\n    \n    return find_video_url(result)"}}],"api":"anthropic-messages","provider":"custom-ark-cn-beijing-volces-com","model":"ark-code-latest","usage":{"input":1099,"output":979,"cacheRead":21816,"cacheWrite":0,"totalTokens":23894,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774103763745}}
